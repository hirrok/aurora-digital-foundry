---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import siteData from '../../../data/ecopetrol-aurora.json';
const base = '/aurora-digital-foundry/clients/ecopetrol-aurora';
const branches = siteData.branches;
---

<BaseLayout
  title="Branches — Ecopetrol Aurora"
  description="Find your nearest Ecopetrol gasoline station across Aurora Province. 8+ branches in Maria Aurora, Baler, Dipaculao, San Luis, and more.">

  <Fragment slot="head">
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@600;700;800&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet" />
  </Fragment>

  <style>
    .fd { font-family: 'Barlow Condensed', sans-serif; }
    .fb { font-family: 'DM Sans', sans-serif; }
    :root { --er: #C41E1E; --eg: #1B5E20; --ed: #0F1923; }
  </style>

  <!-- Emergency Strip -->
  <div style="background:var(--er)" class="text-white text-center text-sm py-2 px-4 fd tracking-widest uppercase">
    ⚡ Emergency Hotline: <span class="ml-1 font-bold">TODO — Add branch emergency contact</span>
  </div>

  <!-- Nav -->
  <nav class="bg-white border-b border-gray-100 sticky top-0 z-50 shadow-sm">
    <div class="max-w-6xl mx-auto px-4 flex items-center justify-between h-16">
      <a href={base + '/'} class="fd text-xl font-black tracking-wider uppercase" style="color:var(--er)">
        ECOPETROL <span class="text-gray-400 font-normal text-sm">AURORA</span>
      </a>
      <div class="hidden md:flex items-center gap-6 text-sm font-medium fb text-gray-700">
        <a href={base + '/branches'} class="font-bold" style="color:var(--er)">Branches</a>
        <a href={base + '/prices'} class="hover:text-red-700 transition-colors">Fuel Prices</a>
        <a href={base + '/lpg'} class="hover:text-red-700 transition-colors">LPG / Solane</a>
        <a href={base + '/fleet'} class="hover:text-red-700 transition-colors">Fleet Accounts</a>
        <a href={base + '/about'} class="hover:text-red-700 transition-colors">About</a>
        <a href={base + '/contact'} style="background:var(--er)" class="text-white px-4 py-2 rounded font-semibold hover:opacity-90 transition-opacity">Contact Us</a>
      </div>
    </div>
  </nav>

  <!-- Page Header -->
  <section style="background:var(--ed)" class="text-white py-16 px-4">
    <div class="max-w-6xl mx-auto">
      <p class="fd text-sm tracking-[0.2em] uppercase mb-2" style="color:var(--er)">Branch Locator</p>
      <h1 class="fd text-5xl md:text-6xl font-black uppercase">FIND YOUR<br/>NEAREST BRANCH</h1>
      <p class="fb text-gray-400 mt-4 max-w-xl">
        {branches.length} branches across Aurora Province. Click any branch for directions and hours.
      </p>
    </div>
  </section>

  <!-- Branch Cards -->
  <section class="bg-gray-50 py-16 px-4">
    <div class="max-w-6xl mx-auto">
      <div class="grid md:grid-cols-2 gap-6">
        {branches.map((b) => (
          <div class="bg-white rounded-lg border border-gray-200 overflow-hidden hover:shadow-lg transition-shadow">
            <!-- Branch Card Header -->
            <div class="flex items-center justify-between px-6 py-4 border-b border-gray-100">
              <div>
                <div class="fd text-xl font-black text-gray-900 uppercase">{b.name}</div>
                <div class="fb text-sm text-gray-500">{b.tag}</div>
              </div>
              <span class="inline-block text-xs font-semibold px-3 py-1 rounded-full fd uppercase tracking-wide"
                    style="background:#dcfce7; color:#166534;">
                TODO: Open / Closed
              </span>
            </div>
            <!-- Branch Details -->
            <div class="px-6 py-4 space-y-3">
              <div class="flex items-start gap-3">
                <span class="text-gray-400 mt-0.5">📍</span>
                <span class="fb text-sm text-gray-700">{b.address}</span>
              </div>
              <div class="flex items-start gap-3">
                <span class="text-gray-400 mt-0.5">🕐</span>
                <span class="fb text-sm text-gray-700">{b.hours}</span>
              </div>
              <div class="flex items-start gap-3">
                <span class="text-gray-400 mt-0.5">📞</span>
                <span class="fb text-sm text-gray-700">{b.phone}</span>
              </div>
              <!-- Products -->
              <div class="flex flex-wrap gap-2 pt-1">
                {b.products.map((p) => (
                  <span class="fb text-xs px-2 py-1 rounded-full border border-gray-200 text-gray-600">{p}</span>
                ))}
              </div>
            </div>
            <!-- Actions -->
            <div class="px-6 pb-4 flex gap-3">
              <a href={b.phone !== 'TODO' ? `tel:${b.phone}` : '#'}
                 style="background:var(--er)"
                 class="flex-1 text-white fd font-bold text-sm py-2 rounded uppercase tracking-wider text-center hover:opacity-90 transition-opacity">
                📞 CALL
              </a>
              <a href={base + '/contact'}
                 class="flex-1 border border-gray-300 text-gray-700 fd font-bold text-sm py-2 rounded uppercase tracking-wider text-center hover:border-red-300 hover:text-red-700 transition-colors">
                GET DIRECTIONS
              </a>
            </div>
            <!-- Maps Embed Placeholder -->
            <div class="mx-6 mb-6 h-32 bg-gray-100 rounded flex items-center justify-center border border-dashed border-gray-300">
              <span class="fb text-xs text-gray-400 text-center px-4">TODO: Embed Google Maps for {b.name}<br/>Replace with: &lt;iframe src="{b.mapsEmbed}"&gt;</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer style="background:var(--ed)" class="text-gray-400 pt-10 pb-6">
    <div class="max-w-6xl mx-auto px-4">
      <div class="flex flex-col md:flex-row items-center justify-between text-sm fb">
        <div class="fd text-lg font-black text-white mb-2 md:mb-0">
          ECOPETROL <span style="color:var(--er)">AURORA</span>
        </div>
        <div class="flex gap-6 text-gray-500">
          <a href={base + '/'} class="hover:text-white transition-colors">Home</a>
          <a href={base + '/prices'} class="hover:text-white transition-colors">Prices</a>
          <a href={base + '/fleet'} class="hover:text-white transition-colors">Fleet</a>
          <a href={base + '/contact'} class="hover:text-white transition-colors">Contact</a>
        </div>
      </div>
      <div class="border-t border-gray-800 mt-6 pt-4 text-xs text-center text-gray-600 fb">
        © 2026 Ecopetrol Aurora · Site by <a href="https://github.com/hirrok" class="hover:text-white transition-colors">Aurora Digital Foundry</a>
      </div>
    </div>
  </footer>

</BaseLayout>
