---
const base = '/aurora-digital-foundry';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/><meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Branch Locator — Ecopetrol Aurora</title>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=Karla:wght@400;600&display=swap" rel="stylesheet"/>
  <style>
    *{box-sizing:border-box;margin:0;padding:0}
    :root{--bg:#0b0f1a;--surface:#111827;--border:rgba(255,255,255,0.07);--text:#e2e8f0;--muted:#64748b;--orange:#f77f00;--green:#10b981;--yellow:#f59e0b;--red:#ef4444;--ff:'Karla',sans-serif;--fh:'Syne',sans-serif;}
    body{font-family:var(--ff);background:var(--bg);color:var(--text);line-height:1.65;}
    a{color:inherit;text-decoration:none;}
    .container{max-width:1200px;margin:0 auto;padding:0 28px;}
    nav{background:rgba(11,15,26,0.95);border-bottom:1px solid var(--border);position:sticky;top:0;z-index:100;}
    .nav-inner{height:66px;display:flex;align-items:center;justify-content:space-between;}
    .nav-logo{display:flex;align-items:center;gap:10px;font-family:var(--fh);font-size:0.9rem;font-weight:800;}
    .nav-mark{background:var(--orange);width:30px;height:30px;border-radius:4px;display:flex;align-items:center;justify-content:center;font-size:0.65rem;font-weight:900;color:#fff;}
    .nav-links{display:flex;gap:24px;list-style:none;}
    .nav-links a{font-size:0.82rem;color:var(--muted);transition:color 0.2s;}
    .nav-links a:hover{color:var(--text);}
    .btn{display:inline-flex;align-items:center;padding:10px 22px;border-radius:4px;font-size:0.82rem;font-weight:700;cursor:pointer;border:none;font-family:var(--ff);transition:all 0.2s;}
    .btn-primary{background:var(--orange);color:#fff;}
    .btn-primary:hover{background:#e06e00;}
    .btn-ghost{background:transparent;color:var(--text);border:1px solid var(--border);}
    .btn-ghost:hover{border-color:var(--orange);color:var(--orange);}
    .btn-sm{padding:7px 16px;font-size:0.75rem;}
    /* HERO */
    .page-hero{padding:60px 0 40px;}
    .tag{display:inline-block;font-size:0.62rem;letter-spacing:0.2em;text-transform:uppercase;color:var(--orange);border:1px solid rgba(247,127,0,0.3);padding:3px 12px;border-radius:2px;margin-bottom:16px;}
    h1{font-family:var(--fh);font-size:clamp(1.8rem,3.5vw,2.8rem);font-weight:800;letter-spacing:-0.02em;margin-bottom:12px;}
    /* BRANCH GRID */
    .branches{display:grid;grid-template-columns:repeat(2,1fr);gap:2px;margin:40px 0;}
    .branch{background:var(--surface);border:1px solid var(--border);padding:0;overflow:hidden;transition:border-color 0.2s;}
    .branch:hover{border-color:rgba(247,127,0,0.3);}
    .branch-map{height:200px;background:var(--bg);border-bottom:1px solid var(--border);position:relative;overflow:hidden;}
    .branch-map iframe{width:100%;height:100%;border:0;filter:invert(0.9) hue-rotate(180deg) brightness(0.85);}
    .map-placeholder{width:100%;height:100%;display:flex;align-items:center;justify-content:center;color:var(--muted);font-size:0.8rem;flex-direction:column;gap:8px;}
    .branch-body{padding:24px;}
    .branch-header{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:12px;}
    .branch-name{font-family:var(--fh);font-size:1rem;font-weight:700;}
    .status-badge{display:inline-flex;align-items:center;gap:6px;font-size:0.62rem;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;padding:3px 10px;border-radius:2px;}
    .status-open{background:rgba(16,185,129,0.1);color:var(--green);border:1px solid rgba(16,185,129,0.2);}
    .status-limited{background:rgba(245,158,11,0.1);color:var(--yellow);border:1px solid rgba(245,158,11,0.2);}
    .status-closed{background:rgba(239,68,68,0.1);color:var(--red);border:1px solid rgba(239,68,68,0.2);}
    .status-dot{width:6px;height:6px;border-radius:50%;background:currentColor;}
    .branch-address{font-size:0.8rem;color:var(--muted);margin-bottom:6px;}
    .branch-hours{font-size:0.78rem;color:var(--muted);margin-bottom:14px;}
    .branch-products{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:16px;}
    .prod-tag{font-size:0.62rem;padding:2px 8px;background:rgba(247,127,0,0.07);border:1px solid rgba(247,127,0,0.18);border-radius:2px;color:var(--muted);}
    .prod-tag.lpg{background:rgba(16,185,129,0.07);border-color:rgba(16,185,129,0.18);color:var(--green);}
    .branch-actions{display:flex;gap:10px;flex-wrap:wrap;}
    footer{background:var(--surface);border-top:1px solid var(--border);padding:28px 0;}
    .footer-bar{display:flex;justify-content:space-between;font-size:0.75rem;color:var(--muted);}
    @media(max-width:900px){.nav-links{display:none;}.branches{grid-template-columns:1fr;}}
  </style>
</head>
<body>
<nav><div class="container"><div class="nav-inner">
  <a href={`${base}/clients/ecopetrol-aurora/`} class="nav-logo"><div class="nav-mark">EC</div>· ECOPETROL</a>
  <ul class="nav-links">
    <li><a href={`${base}/clients/ecopetrol-aurora/branches`} style="color:var(--orange)">Branches</a></li>
    <li><a href={`${base}/clients/ecopetrol-aurora/prices`}>Prices</a></li>
    <li><a href={`${base}/clients/ecopetrol-aurora/lpg`}>LPG</a></li>
    <li><a href={`${base}/clients/ecopetrol-aurora/fleet`}>Fleet</a></li>
    <li><a href={`${base}/clients/ecopetrol-aurora/contact`}>Contact</a></li>
  </ul>
  <a href={`${base}/clients/ecopetrol-aurora/fleet`} class="btn btn-primary">Fleet Accounts</a>
</div></div></nav>

<div class="page-hero"><div class="container">
  <div class="tag">Branch Network</div>
  <h1>8 Locations Across Aurora Province.</h1>
  <p style="font-size:0.95rem;color:var(--muted);max-width:520px;line-height:1.75;">From Maria Aurora to Baler, Dipaculao to San Luis. Find your nearest Ecopetrol station below.</p>
</div></div>

<div class="container">
  <div class="branches" id="branchGrid">
    <!-- Rendered by JS -->
  </div>
  <div style="text-align:center;padding:20px 0 60px;">
    <p style="font-size:0.82rem;color:var(--muted);margin-bottom:16px;">Branch hours and status are updated by our operations team in real time.</p>
    <a href={`${base}/clients/ecopetrol-aurora/contact`} class="btn btn-ghost">Can't find your area? Contact us →</a>
  </div>
</div>

<footer><div class="container"><div class="footer-bar">
  <span>© 2026 Ecopetrol Gasoline Station · Aurora Province</span>
  <a href={`${base}/clients/ecopetrol-aurora/`}>← Back to Home</a>
</div></div></footer>

<script>
  const BRANCHES = [
    { name:'Maria Aurora — Flagship', address:'TODO: Street Address, Maria Aurora, Aurora', hours:'TODO: Operating hours', products:['Unleaded RON 91','Premium RON 95','Diesel Euro 4','Kerosene','Solane LPG'], status:'Open', maps:'TODO_MAPS_EMBED_URL_1', mapsLink:'https://maps.google.com/?q=Maria+Aurora+Aurora' },
    { name:'Baler NE', address:'TODO: Street Address, Baler, Aurora', hours:'TODO: Operating hours', products:['Unleaded RON 91','Diesel Euro 4','Solane LPG'], status:'Open', maps:'TODO_MAPS_EMBED_URL_2', mapsLink:'https://maps.google.com/?q=Baler+Aurora' },
    { name:'Baler Pingit', address:'TODO: Street Address, Baler, Aurora', hours:'TODO: Operating hours', products:['Unleaded RON 91','Diesel Euro 4'], status:'Open', maps:'TODO_MAPS_EMBED_URL_3', mapsLink:'https://maps.google.com/?q=Pingit+Baler+Aurora' },
    { name:'Dipaculao South', address:'TODO: Street Address, Dipaculao, Aurora', hours:'TODO: Operating hours', products:['Unleaded RON 91','Diesel Euro 4','Solane LPG'], status:'Open', maps:'TODO_MAPS_EMBED_URL_4', mapsLink:'https://maps.google.com/?q=Dipaculao+Aurora' },
    { name:'San Luis', address:'TODO: Street Address, San Luis, Aurora', hours:'TODO: Operating hours', products:['Unleaded RON 91','Diesel Euro 4','Solane LPG'], status:'Open', maps:'TODO_MAPS_EMBED_URL_5', mapsLink:'https://maps.google.com/?q=San+Luis+Aurora' },
    { name:'Dinadiawan', address:'TODO: Street Address, Dinadiawan, Aurora', hours:'TODO: Operating hours', products:['Unleaded RON 91','Diesel Euro 4'], status:'Open', maps:'TODO_MAPS_EMBED_URL_6', mapsLink:'https://maps.google.com/?q=Dinadiawan+Aurora' },
    { name:'Detailen — Maria Aurora', address:'TODO: Street Address, Maria Aurora, Aurora', hours:'TODO: Operating hours', products:['Unleaded RON 91','Diesel Euro 4'], status:'Open', maps:'TODO_MAPS_EMBED_URL_7', mapsLink:'https://maps.google.com/?q=Maria+Aurora+Aurora' },
    { name:'Uno — Maria Aurora', address:'TODO: Street Address, Maria Aurora, Aurora', hours:'TODO: Operating hours', products:['Unleaded RON 91','Diesel Euro 4','Solane LPG'], status:'Open', maps:'TODO_MAPS_EMBED_URL_8', mapsLink:'https://maps.google.com/?q=Maria+Aurora+Aurora' },
  ];

  const statusClass = { Open:'status-open', Limited:'status-limited', Closed:'status-closed' };

  document.getElementById('branchGrid').innerHTML = BRANCHES.map(b => `
    <div class="branch">
      <div class="branch-map">
        ${b.maps.startsWith('TODO') ?
          `<div class="map-placeholder"><span style="font-size:1.5rem">📍</span><span>TODO: Add Google Maps embed URL</span><a href="${b.mapsLink}" target="_blank" style="color:var(--orange);font-size:0.78rem">Open in Google Maps →</a></div>` :
          `<iframe src="${b.maps}" allowfullscreen loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>`
        }
      </div>
      <div class="branch-body">
        <div class="branch-header">
          <div class="branch-name">${b.name}</div>
          <div class="status-badge ${statusClass[b.status]}"><span class="status-dot"></span>${b.status}</div>
        </div>
        <div class="branch-address">📍 ${b.address}</div>
        <div class="branch-hours">🕐 ${b.hours}</div>
        <div class="branch-products">
          ${b.products.map(p => `<span class="prod-tag ${p.includes('LPG')?'lpg':''}">${p}</span>`).join('')}
        </div>
        <div class="branch-actions">
          <a href="${b.mapsLink}" target="_blank" class="btn btn-ghost btn-sm">Get Directions ↗</a>
          <a href="/aurora-digital-foundry/clients/ecopetrol-aurora/contact" class="btn btn-primary btn-sm">Call Branch</a>
        </div>
      </div>
    </div>
  `).join('');
</script>
</body>
</html>
