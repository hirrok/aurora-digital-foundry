---
const base = '/aurora-digital-foundry';
const SCRIPT_URL = 'https://script.google.com/macros/s/AKfycbwnL82TNk1DplBIDCbgxwH1rfWhtBqZqMK1A87BETMYaUQYMKMrHgBfBUpEogBclKuf9w/exec';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/><meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Contact — Ecopetrol Aurora</title>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=Karla:wght@400;600&display=swap" rel="stylesheet"/>
  <style>
    *{box-sizing:border-box;margin:0;padding:0}
    :root{--bg:#0b0f1a;--surface:#111827;--border:rgba(255,255,255,0.07);--text:#e2e8f0;--muted:#64748b;--orange:#f77f00;--green:#10b981;--ff:'Karla',sans-serif;--fh:'Syne',sans-serif;}
    body{font-family:var(--ff);background:var(--bg);color:var(--text);line-height:1.65;}
    a{color:inherit;text-decoration:none;}
    .container{max-width:1100px;margin:0 auto;padding:0 28px;}
    nav{background:rgba(11,15,26,0.95);border-bottom:1px solid var(--border);position:sticky;top:0;z-index:100;}
    .nav-inner{height:66px;display:flex;align-items:center;justify-content:space-between;}
    .nav-logo{display:flex;align-items:center;gap:10px;font-family:var(--fh);font-size:0.9rem;font-weight:800;}
    .nav-mark{background:var(--orange);width:30px;height:30px;border-radius:4px;display:flex;align-items:center;justify-content:center;font-size:0.65rem;font-weight:900;color:#fff;}
    .nav-links{display:flex;gap:24px;list-style:none;}
    .nav-links a{font-size:0.82rem;color:var(--muted);transition:color 0.2s;}
    .nav-links a:hover{color:var(--text);}
    .btn{display:inline-flex;align-items:center;padding:10px 22px;border-radius:4px;font-size:0.82rem;font-weight:700;cursor:pointer;border:none;font-family:var(--ff);transition:all 0.2s;}
    .btn-primary{background:var(--orange);color:#fff;}
    .btn-ghost{background:transparent;color:var(--text);border:1px solid var(--border);}
    .page-hero{padding:60px 0 40px;}
    .tag{display:inline-block;font-size:0.62rem;letter-spacing:0.2em;text-transform:uppercase;color:var(--orange);border:1px solid rgba(247,127,0,0.3);padding:3px 12px;border-radius:2px;margin-bottom:16px;}
    h1{font-family:var(--fh);font-size:clamp(1.8rem,3.5vw,2.8rem);font-weight:800;letter-spacing:-0.02em;margin-bottom:12px;}
    .layout{display:grid;grid-template-columns:1fr 380px;gap:60px;padding:0 0 80px;}
    .form-card{background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:36px;}
    .form-title{font-family:var(--fh);font-size:1.1rem;font-weight:800;margin-bottom:6px;}
    .form-sub{font-size:0.82rem;color:var(--muted);margin-bottom:28px;line-height:1.7;}
    .form-group{display:flex;flex-direction:column;gap:6px;margin-bottom:16px;}
    .form-row{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:16px;}
    .form-row .form-group{margin-bottom:0;}
    label{font-size:0.68rem;text-transform:uppercase;letter-spacing:0.1em;color:var(--muted);}
    input,select,textarea{background:var(--bg);border:1px solid var(--border);color:var(--text);padding:11px 14px;font-size:0.875rem;font-family:var(--ff);border-radius:4px;outline:none;transition:border-color 0.2s;width:100%;}
    input:focus,select:focus,textarea:focus{border-color:var(--orange);}
    select option{background:#1a2235;}
    .form-success{background:rgba(16,185,129,0.1);border:1px solid rgba(16,185,129,0.3);color:var(--green);padding:16px;border-radius:4px;font-size:0.875rem;display:none;margin-bottom:20px;}
    /* BRANCH CONTACTS */
    .branch-contacts{display:flex;flex-direction:column;gap:12px;}
    .bc-card{background:var(--surface);border:1px solid var(--border);border-radius:6px;padding:18px;}
    .bc-name{font-size:0.85rem;font-weight:700;margin-bottom:4px;}
    .bc-loc{font-size:0.75rem;color:var(--muted);margin-bottom:8px;}
    .bc-phone{font-size:0.82rem;color:var(--orange);}
    .emergency-card{background:rgba(127,29,29,0.2);border:1px solid rgba(239,68,68,0.25);border-radius:8px;padding:20px;margin-bottom:16px;}
    .em-title{font-size:0.9rem;font-weight:700;color:#fca5a5;margin-bottom:8px;}
    .em-text{font-size:0.8rem;color:#fca5a5;line-height:1.7;}
    footer{background:var(--surface);border-top:1px solid var(--border);padding:28px 0;}
    .footer-bar{display:flex;justify-content:space-between;font-size:0.75rem;color:var(--muted);}
    @media(max-width:900px){.nav-links{display:none;}.layout{grid-template-columns:1fr;}.form-row{grid-template-columns:1fr;}}
  </style>
</head>
<body>
<nav><div class="container"><div class="nav-inner">
  <a href={`${base}/clients/ecopetrol-aurora/`} class="nav-logo"><div class="nav-mark">EC</div>· ECOPETROL</a>
  <ul class="nav-links">
    <li><a href={`${base}/clients/ecopetrol-aurora/branches`}>Branches</a></li>
    <li><a href={`${base}/clients/ecopetrol-aurora/prices`}>Prices</a></li>
    <li><a href={`${base}/clients/ecopetrol-aurora/lpg`}>LPG</a></li>
    <li><a href={`${base}/clients/ecopetrol-aurora/fleet`}>Fleet</a></li>
    <li><a href={`${base}/clients/ecopetrol-aurora/contact`} style="color:var(--orange)">Contact</a></li>
  </ul>
  <a href={`${base}/clients/ecopetrol-aurora/fleet`} class="btn btn-primary">Fleet Accounts</a>
</div></div></nav>

<div class="page-hero"><div class="container">
  <div class="tag">Get in Touch</div>
  <h1>Contact Ecopetrol Aurora.</h1>
  <p style="font-size:0.95rem;color:var(--muted);max-width:480px;line-height:1.75;">For fuel inquiries, fleet account applications, LPG delivery, or general concerns. Our team responds within 1 business day.</p>
</div></div>

<div class="container">
  <div class="layout">
    <div>
      <div class="form-card">
        <div class="form-title">Send a Message</div>
        <div class="form-sub">Fill out the form and our team will get back to you promptly.</div>
        <div class="form-success" id="c-success">✓ Message received. We'll get back to you within 1 business day.</div>
        <form id="contactForm">
          <div class="form-row">
            <div class="form-group">
              <label>Full Name *</label>
              <input type="text" id="c-name" required placeholder="Your name"/>
            </div>
            <div class="form-group">
              <label>Phone Number *</label>
              <input type="tel" id="c-phone" required placeholder="+63 9xx xxx xxxx"/>
            </div>
          </div>
          <div class="form-group">
            <label>Email Address</label>
            <input type="email" id="c-email" placeholder="your@email.com"/>
          </div>
          <div class="form-group">
            <label>Subject *</label>
            <select id="c-subject" required>
              <option value="" disabled selected>What is this about?</option>
              <option>Fleet Account Inquiry</option>
              <option>LPG Delivery Request</option>
              <option>Fuel Prices</option>
              <option>Branch Information</option>
              <option>Complaint or Concern</option>
              <option>Partnership / Business Inquiry</option>
              <option>Other</option>
            </select>
          </div>
          <div class="form-group">
            <label>Nearest Branch</label>
            <select id="c-branch">
              <option value="">Select a branch (optional)</option>
              <option>Maria Aurora — Flagship</option>
              <option>Baler NE</option>
              <option>Baler Pingit</option>
              <option>Dipaculao South</option>
              <option>San Luis</option>
              <option>Dinadiawan</option>
              <option>Detailen — Maria Aurora</option>
              <option>Uno — Maria Aurora</option>
            </select>
          </div>
          <div class="form-group">
            <label>Message *</label>
            <textarea id="c-message" rows="4" required placeholder="How can we help you?"></textarea>
          </div>
          <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;padding:14px;">Send Message →</button>
        </form>
      </div>
    </div>

    <div>
      <div class="emergency-card">
        <div class="em-title">⚠ Emergency Contacts</div>
        <p class="em-text">LPG leak, fuel spill, or safety emergency? Call your nearest branch immediately. Do not use this form for emergencies.</p>
      </div>
      <div class="branch-contacts">
        <p style="font-size:0.7rem;text-transform:uppercase;letter-spacing:0.12em;color:var(--muted);margin-bottom:4px;">Branch Hotlines</p>
        {['Maria Aurora — Flagship','Baler NE','Baler Pingit','Dipaculao South','San Luis','Dinadiawan','Detailen','Uno — Maria Aurora'].map(b => (
          <div class="bc-card">
            <div class="bc-name">{b}</div>
            <div class="bc-loc">Aurora Province</div>
            <div class="bc-phone">TODO: +63 9xx xxx xxxx</div>
          </div>
        ))}
      </div>
    </div>
  </div>
</div>

<footer><div class="container"><div class="footer-bar">
  <span>© 2026 Ecopetrol Gasoline Station · Aurora Province</span>
  <a href={`${base}/clients/ecopetrol-aurora/`}>← Back to Home</a>
</div></div></footer>

<script define:vars={{ SCRIPT_URL }}>
  document.getElementById('contactForm').addEventListener('submit', async function(e) {
    e.preventDefault();
    const btn = this.querySelector('button[type=submit]');
    btn.textContent = 'Sending…'; btn.disabled = true;
    const payload = {
      type: 'contact',
      name: document.getElementById('c-name').value,
      phone: document.getElementById('c-phone').value,
      email: document.getElementById('c-email').value,
      subject: document.getElementById('c-subject').value,
      message: document.getElementById('c-message').value,
      branch: document.getElementById('c-branch').value,
    };
    try {
      await fetch(SCRIPT_URL, { method: 'POST', body: JSON.stringify(payload) });
    } catch {}
    document.getElementById('c-success').style.display = 'block';
    this.reset();
    btn.textContent = 'Send Message →'; btn.disabled = false;
  });
</script>
</body>
</html>
