---
const base = '/aurora-digital-foundry';
const SCRIPT_URL = 'https://script.google.com/macros/s/AKfycbwnL82TNk1DplBIDCbgxwH1rfWhtBqZqMK1A87BETMYaUQYMKMrHgBfBUpEogBclKuf9w/exec';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/><meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>LPG / Solane Delivery — Ecopetrol Aurora</title>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=Karla:wght@400;600&display=swap" rel="stylesheet"/>
  <style>
    *{box-sizing:border-box;margin:0;padding:0}
    :root{--bg:#0b0f1a;--surface:#111827;--border:rgba(255,255,255,0.07);--text:#e2e8f0;--muted:#64748b;--orange:#f77f00;--green:#10b981;--ff:'Karla',sans-serif;--fh:'Syne',sans-serif;}
    body{font-family:var(--ff);background:var(--bg);color:var(--text);line-height:1.65;}
    a{color:inherit;text-decoration:none;}
    .container{max-width:1100px;margin:0 auto;padding:0 28px;}
    nav{background:rgba(11,15,26,0.95);border-bottom:1px solid var(--border);position:sticky;top:0;z-index:100;}
    .nav-inner{height:66px;display:flex;align-items:center;justify-content:space-between;}
    .nav-logo{display:flex;align-items:center;gap:10px;font-family:var(--fh);font-size:0.9rem;font-weight:800;}
    .nav-mark{background:var(--orange);width:30px;height:30px;border-radius:4px;display:flex;align-items:center;justify-content:center;font-size:0.65rem;font-weight:900;color:#fff;}
    .nav-links{display:flex;gap:24px;list-style:none;}
    .nav-links a{font-size:0.82rem;color:var(--muted);transition:color 0.2s;}
    .nav-links a:hover{color:var(--text);}
    .btn{display:inline-flex;align-items:center;padding:10px 22px;border-radius:4px;font-size:0.82rem;font-weight:700;cursor:pointer;border:none;font-family:var(--ff);transition:all 0.2s;}
    .btn-primary{background:var(--orange);color:#fff;}
    .btn-primary:hover{background:#e06e00;}
    .btn-ghost{background:transparent;color:var(--text);border:1px solid var(--border);}
    .btn-ghost:hover{border-color:var(--orange);color:var(--orange);}
    /* HERO */
    .page-hero{padding:80px 0 60px;background:linear-gradient(135deg,var(--bg),rgba(247,127,0,0.04));}
    .tag{display:inline-block;font-size:0.62rem;letter-spacing:0.2em;text-transform:uppercase;color:var(--orange);border:1px solid rgba(247,127,0,0.3);padding:3px 12px;border-radius:2px;margin-bottom:16px;}
    h1{font-family:var(--fh);font-size:clamp(2rem,4vw,3rem);font-weight:800;letter-spacing:-0.02em;margin-bottom:16px;}
    .hero-sub{font-size:1rem;color:var(--muted);max-width:520px;line-height:1.75;}
    /* TYPES */
    .type-grid{display:grid;grid-template-columns:1fr 1fr;gap:2px;margin:60px 0;}
    .type-card{background:var(--surface);border:1px solid var(--border);padding:40px 36px;cursor:pointer;transition:border-color 0.2s;}
    .type-card:hover,.type-card.active{border-color:rgba(247,127,0,0.4);}
    .type-card.active{background:rgba(247,127,0,0.04);}
    .type-icon{font-size:2.5rem;margin-bottom:16px;}
    h2{font-family:var(--fh);font-size:1.3rem;font-weight:800;margin-bottom:10px;}
    .type-desc{font-size:0.85rem;color:var(--muted);line-height:1.7;margin-bottom:20px;}
    .type-features{list-style:none;display:flex;flex-direction:column;gap:6px;}
    .type-features li{font-size:0.82rem;display:flex;align-items:center;gap:8px;color:var(--muted);}
    .type-features li::before{content:'→';color:var(--orange);font-size:0.72rem;}
    /* FORM SECTION */
    .form-section{padding:0 0 80px;}
    .form-layout{display:grid;grid-template-columns:1fr 380px;gap:48px;}
    .form-card{background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:36px;}
    .form-title{font-family:var(--fh);font-size:1.2rem;font-weight:800;margin-bottom:6px;}
    .form-sub{font-size:0.82rem;color:var(--muted);margin-bottom:28px;line-height:1.7;}
    .form-group{display:flex;flex-direction:column;gap:6px;margin-bottom:16px;}
    .form-row{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:16px;}
    .form-row .form-group{margin-bottom:0;}
    label{font-size:0.68rem;text-transform:uppercase;letter-spacing:0.1em;color:var(--muted);}
    input,select,textarea{background:var(--bg);border:1px solid var(--border);color:var(--text);padding:11px 14px;font-size:0.875rem;font-family:var(--ff);border-radius:4px;outline:none;transition:border-color 0.2s;width:100%;}
    input:focus,select:focus,textarea:focus{border-color:var(--orange);}
    select option{background:#1a2235;}
    .form-success{background:rgba(16,185,129,0.1);border:1px solid rgba(16,185,129,0.3);color:var(--green);padding:16px;border-radius:4px;font-size:0.875rem;display:none;margin-bottom:20px;}
    .sidebar-card{background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:24px;margin-bottom:16px;}
    .sidebar-title{font-family:var(--fh);font-size:0.95rem;font-weight:700;margin-bottom:14px;}
    .sidebar-item{display:flex;align-items:flex-start;gap:12px;margin-bottom:14px;font-size:0.82rem;}
    .sidebar-icon{font-size:1.1rem;flex-shrink:0;}
    .sidebar-item-title{font-weight:600;margin-bottom:2px;}
    .sidebar-item-desc{color:var(--muted);font-size:0.78rem;line-height:1.6;}
    .safety-card{background:rgba(127,29,29,0.15);border:1px solid rgba(239,68,68,0.2);border-radius:8px;padding:20px;margin-bottom:16px;}
    .safety-title{font-size:0.82rem;font-weight:700;color:#fca5a5;margin-bottom:8px;}
    .safety-text{font-size:0.78rem;color:#fca5a5;line-height:1.7;}
    footer{background:var(--surface);border-top:1px solid var(--border);padding:28px 0;}
    .footer-bar{display:flex;justify-content:space-between;font-size:0.75rem;color:var(--muted);}
    @media(max-width:900px){.nav-links{display:none;}.form-layout,.type-grid{grid-template-columns:1fr;}.form-row{grid-template-columns:1fr;}}
  </style>
</head>
<body>
<nav><div class="container"><div class="nav-inner">
  <a href={`${base}/clients/ecopetrol-aurora/`} class="nav-logo"><div class="nav-mark">EC</div>· ECOPETROL</a>
  <ul class="nav-links">
    <li><a href={`${base}/clients/ecopetrol-aurora/branches`}>Branches</a></li>
    <li><a href={`${base}/clients/ecopetrol-aurora/prices`}>Prices</a></li>
    <li><a href={`${base}/clients/ecopetrol-aurora/lpg`} style="color:var(--orange)">LPG</a></li>
    <li><a href={`${base}/clients/ecopetrol-aurora/fleet`}>Fleet</a></li>
    <li><a href={`${base}/clients/ecopetrol-aurora/contact`}>Contact</a></li>
  </ul>
  <a href={`${base}/clients/ecopetrol-aurora/fleet`} class="btn btn-primary">Fleet Accounts</a>
</div></div></nav>

<div class="page-hero"><div class="container">
  <div class="tag">Authorized Solane Showroom</div>
  <h1>LPG Delivery &<br/>Cylinder Refills.</h1>
  <p class="hero-sub">Residential and commercial LPG supply across Aurora Province. Authorized Solane distributor with multiple showroom branches.</p>
</div></div>

<div class="container">
  <div class="type-grid">
    <div class="type-card active" onclick="selectType('residential',this)">
      <div class="type-icon">🏠</div>
      <h2>Residential</h2>
      <p class="type-desc">For homes and small kitchens. Cylinder swaps and refills delivered to your door.</p>
      <ul class="type-features">
        <li>11kg Solane cylinder</li>
        <li>22kg Solane cylinder</li>
        <li>Delivery within coverage area</li>
        <li>Same-day or scheduled delivery</li>
      </ul>
    </div>
    <div class="type-card" onclick="selectType('commercial',this)">
      <div class="type-icon">🏭</div>
      <h2>Commercial & Bulk</h2>
      <p class="type-desc">For restaurants, resorts, food businesses, and institutions with high-volume LPG requirements.</p>
      <ul class="type-features">
        <li>Multiple cylinder deliveries</li>
        <li>Bulk commercial supply</li>
        <li>Restaurant and resort accounts</li>
        <li>Scheduled standing orders</li>
      </ul>
    </div>
  </div>

  <div class="form-section">
    <div class="form-layout">
      <div>
        <div class="form-card">
          <div class="form-title">Schedule LPG Delivery</div>
          <div class="form-sub">Fill in your details and we'll confirm your delivery schedule. All deliveries are handled by certified Solane personnel.</div>
          <div class="form-success" id="lpg-success">✓ Request received. We'll call to confirm your delivery schedule.</div>
          <form id="lpgForm">
            <input type="hidden" id="l-type" value="residential"/>
            <div class="form-row">
              <div class="form-group">
                <label>Full Name *</label>
                <input type="text" id="l-name" required placeholder="Your name"/>
              </div>
              <div class="form-group">
                <label>Phone Number *</label>
                <input type="tel" id="l-phone" required placeholder="+63 9xx xxx xxxx"/>
              </div>
            </div>
            <div class="form-group">
              <label>Delivery Address *</label>
              <input type="text" id="l-address" required placeholder="Barangay, Municipality, Aurora"/>
            </div>
            <div class="form-row">
              <div class="form-group">
                <label>Cylinder Size *</label>
                <select id="l-size" required>
                  <option value="" disabled selected>Select size</option>
                  <option>11kg (standard household)</option>
                  <option>22kg (large household / small commercial)</option>
                  <option>50kg (commercial bulk)</option>
                </select>
              </div>
              <div class="form-group">
                <label>Quantity *</label>
                <select id="l-qty" required>
                  <option value="" disabled selected>How many?</option>
                  <option>1 cylinder</option>
                  <option>2 cylinders</option>
                  <option>3–5 cylinders</option>
                  <option>6–10 cylinders</option>
                  <option>10+ cylinders</option>
                </select>
              </div>
            </div>
            <div class="form-row">
              <div class="form-group">
                <label>Nearest Branch</label>
                <select id="l-branch">
                  <option value="" disabled selected>Select branch</option>
                  <option>Maria Aurora — Flagship</option>
                  <option>Baler NE</option>
                  <option>Dipaculao South</option>
                  <option>San Luis</option>
                  <option>Uno — Maria Aurora</option>
                </select>
              </div>
              <div class="form-group">
                <label>Preferred Delivery Date</label>
                <input type="date" id="l-date"/>
              </div>
            </div>
            <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;padding:14px;margin-top:8px;">Schedule Delivery →</button>
          </form>
        </div>
      </div>
      <div>
        <div class="safety-card">
          <div class="safety-title">⚠ LPG Safety Reminder</div>
          <p class="safety-text">If you smell gas, do not turn on lights or use open flames. Open windows, leave the area, and call your nearest Ecopetrol branch immediately. Never attempt to repair cylinders yourself.</p>
        </div>
        <div class="sidebar-card">
          <div class="sidebar-title">Solane Showroom Branches</div>
          <div class="sidebar-item"><div class="sidebar-icon">📍</div><div><div class="sidebar-item-title">Maria Aurora — Flagship</div><div class="sidebar-item-desc">Main showroom. Full cylinder inventory.</div></div></div>
          <div class="sidebar-item"><div class="sidebar-icon">📍</div><div><div class="sidebar-item-title">Baler NE</div><div class="sidebar-item-desc">Serving Baler and surrounding barangays.</div></div></div>
          <div class="sidebar-item"><div class="sidebar-icon">📍</div><div><div class="sidebar-item-title">Dipaculao South</div><div class="sidebar-item-desc">Serving Dipaculao and nearby areas.</div></div></div>
          <div class="sidebar-item"><div class="sidebar-icon">📍</div><div><div class="sidebar-item-title">San Luis & Uno</div><div class="sidebar-item-desc">Southern Aurora coverage.</div></div></div>
        </div>
        <div class="sidebar-card">
          <div class="sidebar-title">Delivery Coverage</div>
          <p style="font-size:0.8rem;color:var(--muted);line-height:1.7;">Delivery coverage varies by branch. Contact your nearest showroom to confirm if your barangay is within the delivery area. Some remote areas may require pickup at the showroom.</p>
        </div>
      </div>
    </div>
  </div>
</div>

<footer><div class="container"><div class="footer-bar">
  <span>© 2026 Ecopetrol Gasoline Station · Aurora Province</span>
  <a href={`${base}/clients/ecopetrol-aurora/`}>← Back to Home</a>
</div></div></footer>

<script define:vars={{ SCRIPT_URL }}>
  function selectType(type, card) {
    document.querySelectorAll('.type-card').forEach(c => c.classList.remove('active'));
    card.classList.add('active');
    document.getElementById('l-type').value = type;
  }

  document.getElementById('lpgForm').addEventListener('submit', async function(e) {
    e.preventDefault();
    const btn = this.querySelector('button[type=submit]');
    btn.textContent = 'Submitting…'; btn.disabled = true;
    const payload = {
      type: 'lpg',
      name: document.getElementById('l-name').value,
      phone: document.getElementById('l-phone').value,
      address: document.getElementById('l-address').value,
      cylinderSize: document.getElementById('l-size').value,
      quantity: document.getElementById('l-qty').value,
      branch: document.getElementById('l-branch').value,
      deliveryDate: document.getElementById('l-date').value,
      customerType: document.getElementById('l-type').value,
    };
    try {
      await fetch(SCRIPT_URL, { method: 'POST', body: JSON.stringify(payload) });
    } catch {}
    document.getElementById('lpg-success').style.display = 'block';
    this.reset();
    btn.textContent = 'Schedule Delivery →'; btn.disabled = false;
  });
</script>
</body>
</html>
