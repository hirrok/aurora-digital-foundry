---
import BaseLayout from '../../../layouts/BaseLayout.astro';
const base = '/aurora-digital-foundry/clients/ecopetrol-aurora';
const showrooms = [
  "Maria Aurora (Main)", "Maria Aurora (Detailen)", "Maria Aurora (Uno)", "San Luis"
];
---

<BaseLayout
  title="LPG / Solane — Ecopetrol Aurora"
  description="Authorized Solane LPG showroom. Residential and commercial LPG delivery across Aurora Province. Order online or inquire for bulk supply.">

  <Fragment slot="head">
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@600;700;800&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet" />
  </Fragment>

  <style>
    .fd { font-family: 'Barlow Condensed', sans-serif; }
    .fb { font-family: 'DM Sans', sans-serif; }
    :root { --er: #C41E1E; --eg: #1B5E20; --ed: #0F1923; }
    .form-input {
      width: 100%; border: 1px solid #d1d5db; border-radius: 0.375rem;
      padding: 0.625rem 0.875rem; font-size: 0.875rem;
      font-family: 'DM Sans', sans-serif;
    }
    .form-input:focus { outline: 2px solid var(--eg); outline-offset: 1px; }
    .form-label { display: block; font-size: 0.75rem; font-weight: 600; text-transform: uppercase;
      letter-spacing: 0.1em; color: #374151; margin-bottom: 0.375rem; font-family: 'Barlow Condensed', sans-serif; }
  </style>

  <div style="background:var(--er)" class="text-white text-center text-sm py-2 px-4 fd tracking-widest uppercase">
    ⚡ Emergency Hotline: <span class="ml-1 font-bold">TODO — Add branch emergency contact</span>
  </div>

  <nav class="bg-white border-b border-gray-100 sticky top-0 z-50 shadow-sm">
    <div class="max-w-6xl mx-auto px-4 flex items-center justify-between h-16">
      <a href={base + '/'} class="fd text-xl font-black tracking-wider uppercase" style="color:var(--er)">
        ECOPETROL <span class="text-gray-400 font-normal text-sm">AURORA</span>
      </a>
      <div class="hidden md:flex items-center gap-6 text-sm font-medium fb text-gray-700">
        <a href={base + '/branches'} class="hover:text-red-700 transition-colors">Branches</a>
        <a href={base + '/prices'} class="hover:text-red-700 transition-colors">Fuel Prices</a>
        <a href={base + '/lpg'} class="font-bold" style="color:var(--eg)">LPG / Solane</a>
        <a href={base + '/fleet'} class="hover:text-red-700 transition-colors">Fleet Accounts</a>
        <a href={base + '/about'} class="hover:text-red-700 transition-colors">About</a>
        <a href={base + '/contact'} style="background:var(--er)" class="text-white px-4 py-2 rounded font-semibold hover:opacity-90 transition-opacity">Contact Us</a>
      </div>
    </div>
  </nav>

  <!-- Hero -->
  <section style="background:var(--eg)" class="text-white py-16 px-4">
    <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-12 items-center">
      <div>
        <p class="fd text-sm tracking-[0.25em] uppercase text-green-300 mb-2">Authorized Solane Showroom</p>
        <h1 class="fd text-5xl md:text-6xl font-black uppercase leading-tight">LPG DELIVERY<br/>FOR HOME &<br/>BUSINESS</h1>
        <p class="fb text-green-100 mt-4 max-w-md">
          Ecopetrol Aurora operates authorized Solane showrooms across Maria Aurora and San Luis,
          serving residential households, commercial kitchens, and industrial facilities.
        </p>
        <div class="flex flex-wrap gap-3 mt-6">
          <span class="bg-white/20 text-white fd text-sm font-bold px-4 py-2 rounded-full uppercase tracking-wide">Residential Delivery</span>
          <span class="bg-white/20 text-white fd text-sm font-bold px-4 py-2 rounded-full uppercase tracking-wide">Commercial / Bulk</span>
          <span class="bg-white/20 text-white fd text-sm font-bold px-4 py-2 rounded-full uppercase tracking-wide">Industrial Supply</span>
        </div>
      </div>
      <div>
        <img
          src="https://images.unsplash.com/photo-1585771742866-1e1efa6deec5?auto=format&fit=crop&w=900&q=80"
          alt="Solane LPG cylinders — Ecopetrol Aurora showroom"
          class="rounded-xl w-full object-cover h-64 md:h-80 shadow-xl"
        />
      </div>
    </div>
  </section>

  <!-- Showroom Coverage -->
  <section class="bg-green-50 py-10 px-4">
    <div class="max-w-4xl mx-auto text-center">
      <p class="fd text-sm tracking-[0.2em] uppercase text-green-700 mb-2">Showroom Network</p>
      <h2 class="fd text-3xl font-black text-gray-900 uppercase mb-6">LPG AVAILABLE AT THESE BRANCHES</h2>
      <div class="flex flex-wrap justify-center gap-3">
        {showrooms.map(s => (
          <span class="bg-white border border-green-200 text-green-800 fd font-bold text-sm px-4 py-2 rounded-full uppercase tracking-wide shadow-sm">
            {s}
          </span>
        ))}
      </div>
      <p class="fb text-sm text-gray-500 mt-4">Delivery coverage areas vary per showroom. Inquire below for your location.</p>
    </div>
  </section>

  <!-- Forms Section -->
  <section class="bg-white py-16 px-4">
    <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-10">

      <!-- Residential Form -->
      <div class="bg-green-50 rounded-xl p-8 border border-green-200">
        <div class="fd text-sm tracking-[0.2em] uppercase text-green-700 mb-1">For Homes & Small Businesses</div>
        <h2 class="fd text-3xl font-black text-gray-900 uppercase mb-6">RESIDENTIAL ORDER</h2>
        <form action="https://formspree.io/f/TODO-RESIDENTIAL" method="POST" class="space-y-4">
          <div>
            <label class="form-label">Full Name</label>
            <input type="text" name="name" required placeholder="Your name" class="form-input" />
          </div>
          <div>
            <label class="form-label">Phone Number</label>
            <input type="tel" name="phone" required placeholder="09XX XXX XXXX" class="form-input" />
          </div>
          <div>
            <label class="form-label">Delivery Address</label>
            <input type="text" name="address" required placeholder="Barangay, Municipality, Aurora" class="form-input" />
          </div>
          <div>
            <label class="form-label">Nearest Showroom</label>
            <select name="showroom" required class="form-input bg-white">
              <option value="">Select showroom</option>
              {showrooms.map(s => <option value={s}>{s}</option>)}
            </select>
          </div>
          <div>
            <label class="form-label">Cylinder Size</label>
            <select name="cylinder" class="form-input bg-white">
              <option value="small">Small (TODO kg)</option>
              <option value="medium">Medium (TODO kg)</option>
              <option value="large">Large (TODO kg)</option>
            </select>
          </div>
          <div>
            <label class="form-label">Preferred Delivery Date</label>
            <input type="date" name="date" class="form-input" />
          </div>
          <input type="hidden" name="_subject" value="Residential LPG Order — Ecopetrol Aurora" />
          <button type="submit" style="background:var(--eg)" class="w-full text-white fd font-bold py-3 rounded uppercase tracking-widest hover:opacity-90 transition-opacity">
            SUBMIT ORDER REQUEST
          </button>
          <p class="fb text-xs text-gray-500 text-center">TODO: Replace Formspree ID before going live</p>
        </form>
      </div>

      <!-- Commercial Form -->
      <div class="bg-gray-900 rounded-xl p-8 border border-gray-700">
        <div class="fd text-sm tracking-[0.2em] uppercase text-green-400 mb-1">For Restaurants, Factories & Institutions</div>
        <h2 class="fd text-3xl font-black text-white uppercase mb-6">COMMERCIAL / BULK INQUIRY</h2>
        <form action="https://formspree.io/f/TODO-COMMERCIAL" method="POST" class="space-y-4">
          <div>
            <label class="form-label text-gray-300">Company / Business Name</label>
            <input type="text" name="company" required placeholder="Business name" class="form-input bg-gray-800 border-gray-700 text-white placeholder-gray-500" />
          </div>
          <div>
            <label class="form-label text-gray-300">Contact Person</label>
            <input type="text" name="contact" required placeholder="Name and role" class="form-input bg-gray-800 border-gray-700 text-white placeholder-gray-500" />
          </div>
          <div>
            <label class="form-label text-gray-300">Phone Number</label>
            <input type="tel" name="phone" required placeholder="09XX XXX XXXX" class="form-input bg-gray-800 border-gray-700 text-white placeholder-gray-500" />
          </div>
          <div>
            <label class="form-label text-gray-300">Location / Delivery Area</label>
            <input type="text" name="location" required placeholder="Municipality, Aurora" class="form-input bg-gray-800 border-gray-700 text-white placeholder-gray-500" />
          </div>
          <div>
            <label class="form-label text-gray-300">Estimated Monthly Volume</label>
            <select name="volume" class="form-input bg-gray-800 border-gray-700 text-white">
              <option value="small">Small (1–10 cylinders/month)</option>
              <option value="medium">Medium (11–50 cylinders/month)</option>
              <option value="large">Large (50+ cylinders/month)</option>
              <option value="bulk">Bulk / Tank delivery</option>
            </select>
          </div>
          <div>
            <label class="form-label text-gray-300">Type of Business</label>
            <input type="text" name="business_type" placeholder="e.g. Restaurant, Factory, Hotel" class="form-input bg-gray-800 border-gray-700 text-white placeholder-gray-500" />
          </div>
          <div>
            <label class="form-label text-gray-300">Additional Notes</label>
            <textarea name="notes" rows="2" placeholder="Delivery schedule, special requirements..." class="form-input bg-gray-800 border-gray-700 text-white placeholder-gray-500"></textarea>
          </div>
          <input type="hidden" name="_subject" value="Commercial LPG Inquiry — Ecopetrol Aurora" />
          <button type="submit" style="background:var(--eg)" class="w-full text-white fd font-bold py-3 rounded uppercase tracking-widest hover:opacity-90 transition-opacity">
            SEND INQUIRY
          </button>
          <p class="fb text-xs text-gray-500 text-center">TODO: Replace Formspree ID before going live</p>
        </form>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer style="background:var(--ed)" class="text-gray-400 pt-10 pb-6">
    <div class="max-w-6xl mx-auto px-4">
      <div class="flex flex-col md:flex-row items-center justify-between text-sm fb">
        <div class="fd text-lg font-black text-white mb-2 md:mb-0">ECOPETROL <span style="color:var(--er)">AURORA</span></div>
        <div class="flex gap-6 text-gray-500">
          <a href={base + '/'} class="hover:text-white transition-colors">Home</a>
          <a href={base + '/branches'} class="hover:text-white transition-colors">Branches</a>
          <a href={base + '/fleet'} class="hover:text-white transition-colors">Fleet</a>
          <a href={base + '/contact'} class="hover:text-white transition-colors">Contact</a>
        </div>
      </div>
      <div class="border-t border-gray-800 mt-6 pt-4 text-xs text-center text-gray-600 fb">
        © 2026 Ecopetrol Aurora · Site by <a href="https://github.com/hirrok" class="hover:text-white">Aurora Digital Foundry</a>
      </div>
    </div>
  </footer>

</BaseLayout>
