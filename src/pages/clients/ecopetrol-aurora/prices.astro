---
const base = '/aurora-digital-foundry';
const SCRIPT_URL = 'https://script.google.com/macros/s/AKfycbwnL82TNk1DplBIDCbgxwH1rfWhtBqZqMK1A87BETMYaUQYMKMrHgBfBUpEogBclKuf9w/exec';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/><meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Fuel Prices — Ecopetrol Aurora</title>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=Karla:wght@400;600&display=swap" rel="stylesheet"/>
  <style>
    *{box-sizing:border-box;margin:0;padding:0}
    :root{--bg:#0b0f1a;--surface:#111827;--border:rgba(255,255,255,0.07);--text:#e2e8f0;--muted:#64748b;--orange:#f77f00;--green:#10b981;--red:#ef4444;--ff:'Karla',sans-serif;--fh:'Syne',sans-serif;}
    body{font-family:var(--ff);background:var(--bg);color:var(--text);line-height:1.65;}
    a{color:inherit;text-decoration:none;}
    .container{max-width:1100px;margin:0 auto;padding:0 28px;}
    nav{background:rgba(11,15,26,0.95);border-bottom:1px solid var(--border);position:sticky;top:0;z-index:100;}
    .nav-inner{height:66px;display:flex;align-items:center;justify-content:space-between;}
    .nav-logo{display:flex;align-items:center;gap:10px;font-family:var(--fh);font-size:0.9rem;font-weight:800;}
    .nav-mark{background:var(--orange);width:30px;height:30px;border-radius:4px;display:flex;align-items:center;justify-content:center;font-size:0.65rem;font-weight:900;color:#fff;}
    .nav-links{display:flex;gap:24px;list-style:none;}
    .nav-links a{font-size:0.82rem;color:var(--muted);transition:color 0.2s;}
    .nav-links a:hover{color:var(--text);}
    .btn{display:inline-flex;align-items:center;padding:10px 22px;border-radius:4px;font-size:0.82rem;font-weight:700;cursor:pointer;border:none;font-family:var(--ff);transition:all 0.2s;}
    .btn-primary{background:var(--orange);color:#fff;}
    .btn-ghost{background:transparent;color:var(--text);border:1px solid var(--border);}
    .btn-ghost:hover{border-color:var(--orange);color:var(--orange);}
    /* HERO */
    .page-hero{padding:60px 0 40px;}
    .tag{display:inline-block;font-size:0.62rem;letter-spacing:0.2em;text-transform:uppercase;color:var(--orange);border:1px solid rgba(247,127,0,0.3);padding:3px 12px;border-radius:2px;margin-bottom:16px;}
    h1{font-family:var(--fh);font-size:clamp(2rem,4vw,3rem);font-weight:800;letter-spacing:-0.02em;margin-bottom:12px;}
    .hero-sub{font-size:0.9rem;color:var(--muted);max-width:520px;line-height:1.75;}
    /* PRICE BOARD */
    .price-board{display:grid;grid-template-columns:repeat(2,1fr);gap:2px;margin:48px 0;}
    .price-card{background:var(--surface);border:1px solid var(--border);padding:40px 36px;position:relative;overflow:hidden;}
    .price-card::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(90deg,var(--orange),transparent);}
    .price-product{font-size:0.72rem;text-transform:uppercase;letter-spacing:0.15em;color:var(--muted);margin-bottom:12px;}
    .price-value{font-family:var(--fh);font-size:3.5rem;font-weight:800;letter-spacing:-0.04em;line-height:1;color:var(--text);}
    .price-unit{font-size:0.9rem;color:var(--muted);font-family:var(--ff);font-weight:400;}
    .price-change{display:flex;align-items:center;gap:6px;margin-top:12px;font-size:0.78rem;}
    .change-up{color:var(--red);}
    .change-down{color:var(--green);}
    .change-flat{color:var(--muted);}
    .price-desc{font-size:0.78rem;color:var(--muted);margin-top:8px;line-height:1.6;}
    /* UPDATE INFO */
    .update-bar{background:var(--surface);border:1px solid var(--border);border-radius:6px;padding:16px 24px;display:flex;align-items:center;justify-content:space-between;margin-bottom:40px;flex-wrap:wrap;gap:12px;}
    .update-text{font-size:0.82rem;color:var(--muted);}
    .update-text strong{color:var(--text);}
    /* DOE NOTE */
    .doe-note{background:rgba(247,127,0,0.05);border:1px solid rgba(247,127,0,0.15);border-radius:6px;padding:20px 24px;margin-bottom:60px;}
    .doe-title{font-size:0.82rem;font-weight:700;margin-bottom:6px;}
    .doe-text{font-size:0.78rem;color:var(--muted);line-height:1.7;}
    /* HISTORY */
    .history-section{margin-bottom:60px;}
    h2{font-family:var(--fh);font-size:1.4rem;font-weight:800;margin-bottom:20px;}
    table{width:100%;border-collapse:collapse;background:var(--surface);border:1px solid var(--border);border-radius:6px;overflow:hidden;}
    th{padding:12px 20px;text-align:left;font-size:0.65rem;text-transform:uppercase;letter-spacing:0.1em;color:var(--muted);border-bottom:1px solid var(--border);}
    td{padding:12px 20px;font-size:0.85rem;border-bottom:1px solid var(--border);}
    tr:last-child td{border-bottom:none;}
    footer{background:var(--surface);border-top:1px solid var(--border);padding:28px 0;}
    .footer-bar{display:flex;justify-content:space-between;font-size:0.75rem;color:var(--muted);}
    @media(max-width:700px){.nav-links{display:none;}.price-board{grid-template-columns:1fr;}}
  </style>
</head>
<body>
<nav><div class="container"><div class="nav-inner">
  <a href={`${base}/clients/ecopetrol-aurora/`} class="nav-logo"><div class="nav-mark">EC</div>· ECOPETROL</a>
  <ul class="nav-links">
    <li><a href={`${base}/clients/ecopetrol-aurora/branches`}>Branches</a></li>
    <li><a href={`${base}/clients/ecopetrol-aurora/prices`} style="color:var(--orange)">Prices</a></li>
    <li><a href={`${base}/clients/ecopetrol-aurora/lpg`}>LPG</a></li>
    <li><a href={`${base}/clients/ecopetrol-aurora/fleet`}>Fleet</a></li>
    <li><a href={`${base}/clients/ecopetrol-aurora/contact`}>Contact</a></li>
  </ul>
  <a href={`${base}/clients/ecopetrol-aurora/fleet`} class="btn btn-primary">Fleet Accounts</a>
</div></div></nav>

<div class="page-hero"><div class="container">
  <div class="tag">Fuel Price Board</div>
  <h1>Today's Pump Prices.</h1>
  <p class="hero-sub">Updated by our operations team. All prices per liter, VAT inclusive, as mandated by the Department of Energy.</p>
</div></div>

<div class="container">
  <div class="update-bar">
    <div class="update-text">Last updated: <strong id="lastUpdated">Loading…</strong></div>
    <div style="display:flex;gap:12px;align-items:center;">
      <span style="font-size:0.75rem;color:var(--muted)">Prices subject to change without prior notice</span>
      <a href={`${base}/clients/ecopetrol-aurora/fleet`} class="btn btn-ghost" style="padding:6px 16px;font-size:0.75rem;">Fleet Pricing →</a>
    </div>
  </div>

  <div class="price-board" id="priceBoard">
    <div class="price-card">
      <div class="price-product">Unleaded Gasoline RON 91</div>
      <div class="price-value" id="p-ron91">₱89.50</div>
      <div class="price-unit">per liter</div>
      <div class="price-desc">Standard unleaded gasoline for passenger vehicles, motorcycles, and light trucks.</div>
    </div>
    <div class="price-card">
      <div class="price-product">Premium Gasoline RON 95</div>
      <div class="price-value" id="p-ron95">₱94.00</div>
      <div class="price-unit">per liter</div>
      <div class="price-desc">Higher octane premium fuel for modern engines requiring higher compression ratios.</div>
    </div>
    <div class="price-card">
      <div class="price-product">Diesel Euro 4</div>
      <div class="price-value" id="p-diesel">₱84.50</div>
      <div class="price-unit">per liter</div>
      <div class="price-desc">Euro 4 compliant diesel for trucks, heavy equipment, buses, and commercial vehicles.</div>
    </div>
    <div class="price-card">
      <div class="price-product">Kerosene</div>
      <div class="price-value" id="p-kerosene">₱118.50</div>
      <div class="price-unit">per liter</div>
      <div class="price-desc">Household and commercial kerosene. Available at selected branches.</div>
    </div>
  </div>

  <div class="doe-note">
    <div class="doe-title">⚖️ DOE Price Display Compliance</div>
    <p class="doe-text">Pursuant to Department of Energy regulations, Ecopetrol Aurora publicly displays current fuel prices at all branch locations and on this website. Prices are updated upon any change in pump rates. For fleet account pricing inquiries, contact our operations team directly.</p>
  </div>

  <div class="history-section">
    <h2>Recent Price History</h2>
    <table>
      <thead><tr><th>Date</th><th>RON 91</th><th>RON 95</th><th>Diesel</th><th>Kerosene</th></tr></thead>
      <tbody id="priceHistory"><tr><td colspan="5" style="color:var(--muted);font-size:0.85rem;">Loading price history…</td></tr></tbody>
    </table>
  </div>
</div>

<footer><div class="container"><div class="footer-bar">
  <span>© 2026 Ecopetrol Gasoline Station · Aurora Province</span>
  <a href={`${base}/clients/ecopetrol-aurora/`}>← Back to Home</a>
</div></div></footer>

<script define:vars={{ SCRIPT_URL }}>
  async function loadPrices() {
    try {
      const res = await fetch(`${SCRIPT_URL}?type=prices`);
      const json = await res.json();
      const data = json.data || [];
      if (data.length > 0) {
        const latest = data[0];
        document.getElementById('p-ron91').textContent = `₱${latest.RON91}`;
        document.getElementById('p-ron95').textContent = `₱${latest.RON95}`;
        document.getElementById('p-diesel').textContent = `₱${latest.Diesel}`;
        document.getElementById('p-kerosene').textContent = `₱${latest.Kerosene}`;
        const d = new Date(latest.Timestamp);
        document.getElementById('lastUpdated').textContent = d.toLocaleString('en-PH', {month:'long',day:'numeric',year:'numeric',hour:'2-digit',minute:'2-digit'});
      }
      const history = data.slice(0, 10);
      document.getElementById('priceHistory').innerHTML = history.map(r => {
        const d = new Date(r.Timestamp);
        return `<tr><td>${d.toLocaleDateString('en-PH',{month:'short',day:'numeric',year:'numeric'})}</td><td>₱${r.RON91}</td><td>₱${r.RON95}</td><td>₱${r.Diesel}</td><td>₱${r.Kerosene}</td></tr>`;
      }).join('') || '<tr><td colspan="5" style="color:var(--muted)">No history yet.</td></tr>';
    } catch {
      document.getElementById('lastUpdated').textContent = new Date().toLocaleDateString('en-PH',{month:'long',day:'numeric',year:'numeric'}) + ' (demo mode)';
      document.getElementById('priceHistory').innerHTML = '<tr><td colspan="5" style="color:var(--muted);font-size:0.85rem;">Connect Google Sheets to see price history.</td></tr>';
    }
  }
  loadPrices();
</script>
</body>
</html>
