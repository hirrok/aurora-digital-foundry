---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import siteData from '../../../data/ecopetrol-aurora.json';
const base = '/aurora-digital-foundry/clients/ecopetrol-aurora';
const fuels = siteData.fuels;
---

<BaseLayout
  title="Fuel Prices — Ecopetrol Aurora"
  description="Today's fuel prices at Ecopetrol Aurora. Diesel, gasoline, and premium fuel rates across Aurora Province. Updated per DOE guidelines.">

  <Fragment slot="head">
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@600;700;800&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet" />
  </Fragment>

  <style>
    .fd { font-family: 'Barlow Condensed', sans-serif; }
    .fb { font-family: 'DM Sans', sans-serif; }
    :root { --er: #C41E1E; --eg: #1B5E20; --ea: #D97706; --ed: #0F1923; }
    .price-board { background: var(--ed); }
    .price-row { border-bottom: 1px solid #1e2d3d; }
    .price-row:last-child { border-bottom: none; }
    .price-display { font-size: clamp(2rem, 6vw, 3.5rem); }
  </style>

  <div style="background:var(--er)" class="text-white text-center text-sm py-2 px-4 fd tracking-widest uppercase">
    ⚡ Emergency Hotline: <span class="ml-1 font-bold">TODO — Add branch emergency contact</span>
  </div>

  <nav class="bg-white border-b border-gray-100 sticky top-0 z-50 shadow-sm">
    <div class="max-w-6xl mx-auto px-4 flex items-center justify-between h-16">
      <a href={base + '/'} class="fd text-xl font-black tracking-wider uppercase" style="color:var(--er)">
        ECOPETROL <span class="text-gray-400 font-normal text-sm">AURORA</span>
      </a>
      <div class="hidden md:flex items-center gap-6 text-sm font-medium fb text-gray-700">
        <a href={base + '/branches'} class="hover:text-red-700 transition-colors">Branches</a>
        <a href={base + '/prices'} class="font-bold" style="color:var(--er)">Fuel Prices</a>
        <a href={base + '/lpg'} class="hover:text-red-700 transition-colors">LPG / Solane</a>
        <a href={base + '/fleet'} class="hover:text-red-700 transition-colors">Fleet Accounts</a>
        <a href={base + '/about'} class="hover:text-red-700 transition-colors">About</a>
        <a href={base + '/contact'} style="background:var(--er)" class="text-white px-4 py-2 rounded font-semibold hover:opacity-90 transition-opacity">Contact Us</a>
      </div>
    </div>
  </nav>

  <!-- Header -->
  <section style="background:var(--ed)" class="text-white py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <p class="fd text-sm tracking-[0.25em] uppercase mb-2" style="color:var(--er)">Live Price Board</p>
      <h1 class="fd text-5xl md:text-6xl font-black uppercase">TODAY'S<br/>FUEL PRICES</h1>
      <p class="fb text-gray-400 mt-3 max-w-lg">
        Prices updated by Ecopetrol Aurora staff per DOE guidelines. 
        Rates apply across all Aurora branches unless noted otherwise.
      </p>
    </div>
  </section>

  <!-- Price Board -->
  <section class="bg-gray-100 py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <div class="price-board rounded-xl overflow-hidden shadow-2xl">
        <!-- Board Header -->
        <div class="px-8 py-4 flex items-center justify-between" style="background:#080f16; border-bottom: 1px solid #1e2d3d">
          <div class="flex items-center gap-3">
            <div class="w-2 h-2 rounded-full bg-green-400 animate-pulse"></div>
            <span class="fd text-sm tracking-[0.2em] uppercase text-gray-400">Ecopetrol Aurora — Price Board</span>
          </div>
          <span class="fd text-xs text-gray-600 uppercase tracking-wider">Per Liter · PHP</span>
        </div>

        <!-- Fuel Rows -->
        {fuels.map((fuel, i) => (
          <div class="price-row px-8 py-6 flex items-center justify-between">
            <div>
              <div class="fd text-xl font-bold text-white uppercase tracking-wide">{fuel.type}</div>
              <div class="fb text-xs text-gray-500 mt-0.5">{fuel.unit}</div>
            </div>
            <div class="text-right">
              {fuel.price === 'TODO'
                ? <div class="fd text-gray-500 text-lg tracking-widest">— updating —</div>
                : <div class="fd font-black price-display" style="color:var(--ea)">₱ {fuel.price}</div>
              }
            </div>
          </div>
        ))}

        <!-- Board Footer -->
        <div class="px-8 py-4 flex flex-col md:flex-row items-start md:items-center justify-between gap-2" style="background:#080f16; border-top: 1px solid #1e2d3d">
          <p class="fb text-xs text-gray-600">
            Last updated: <span class="text-gray-400">{siteData.lastUpdated}</span>
          </p>
          <p class="fb text-xs text-gray-600 max-w-md text-right">
            {siteData.disclaimer}
          </p>
        </div>
      </div>

      <!-- DOE Note -->
      <div class="mt-6 bg-amber-50 border border-amber-200 rounded-lg px-6 py-4">
        <p class="fb text-sm text-amber-800">
          <span class="font-semibold">DOE Compliance:</span> Ecopetrol Aurora prices follow Department of Energy guidelines.
          Stations are not allowed to implement unscheduled or unauthorized price increases.
          Report any concerns to DOE's eGovPH Gas Station Concerns channel.
        </p>
      </div>

      <!-- Price Alert CTA -->
      <div class="mt-8 bg-white rounded-xl border border-gray-200 p-8 text-center">
        <div class="fd text-2xl font-black text-gray-900 uppercase mb-2">GET PRICE CHANGE ALERTS</div>
        <p class="fb text-gray-500 mb-6 max-w-md mx-auto">
          Fleet managers and daily commuters — message us on Facebook to subscribe to 
          Ecopetrol Aurora price updates. Never miss a DOE price adjustment.
        </p>
        <a href="https://m.me/TODO"
           class="inline-block fd font-bold text-white px-8 py-3 uppercase tracking-widest hover:opacity-90 transition-opacity"
           style="background:var(--er)">
          📲 MESSAGE US ON FACEBOOK
        </a>
        <p class="fb text-xs text-gray-400 mt-4">TODO: Replace "TODO" in the link with your Facebook Page username</p>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer style="background:var(--ed)" class="text-gray-400 pt-10 pb-6">
    <div class="max-w-6xl mx-auto px-4">
      <div class="flex flex-col md:flex-row items-center justify-between text-sm fb">
        <div class="fd text-lg font-black text-white mb-2 md:mb-0">ECOPETROL <span style="color:var(--er)">AURORA</span></div>
        <div class="flex gap-6 text-gray-500">
          <a href={base + '/'} class="hover:text-white transition-colors">Home</a>
          <a href={base + '/branches'} class="hover:text-white transition-colors">Branches</a>
          <a href={base + '/fleet'} class="hover:text-white transition-colors">Fleet</a>
          <a href={base + '/contact'} class="hover:text-white transition-colors">Contact</a>
        </div>
      </div>
      <div class="border-t border-gray-800 mt-6 pt-4 text-xs text-center text-gray-600 fb">
        © 2026 Ecopetrol Aurora · Site by <a href="https://github.com/hirrok" class="hover:text-white">Aurora Digital Foundry</a>
      </div>
    </div>
  </footer>

</BaseLayout>
