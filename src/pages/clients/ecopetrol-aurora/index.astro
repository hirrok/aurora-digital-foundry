---
// Ecopetrol Aurora — Homepage
// Aurora Digital Foundry · Volt Template
const base = '/aurora-digital-foundry';
const SCRIPT_URL = 'https://script.google.com/macros/s/AKfycbwnL82TNk1DplBIDCbgxwH1rfWhtBqZqMK1A87BETMYaUQYMKMrHgBfBUpEogBclKuf9w/exec';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Ecopetrol Aurora — Fuel & LPG Across Aurora Province</title>
  <meta name="description" content="Aurora Province's fuel infrastructure network. 8 branches across Maria Aurora, Baler, Dipaculao, San Luis and beyond. Gasoline, diesel, and Solane LPG."/>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=Karla:wght@400;500;600&display=swap" rel="stylesheet"/>
  <style>
    *{box-sizing:border-box;margin:0;padding:0}
    :root{
      --bg:#0b0f1a;--surface:#111827;--surface2:#1a2235;
      --border:rgba(255,255,255,0.07);--text:#e2e8f0;--muted:#64748b;
      --orange:#f77f00;--blue:#0077b6;--green:#10b981;
      --ff:'Karla',sans-serif;--fh:'Syne',sans-serif;
    }
    body{font-family:var(--ff);background:var(--bg);color:var(--text);line-height:1.65;overflow-x:hidden;}
    a{color:inherit;text-decoration:none;}

    /* EMERGENCY BAR */
    .emergency{background:#7f1d1d;color:#fca5a5;font-size:0.75rem;text-align:center;padding:8px 20px;display:flex;align-items:center;justify-content:center;gap:16px;}
    .emergency a{color:#fca5a5;text-decoration:underline;font-weight:600;}

    /* NAV */
    nav{background:rgba(11,15,26,0.9);backdrop-filter:blur(12px);border-bottom:1px solid var(--border);position:sticky;top:0;z-index:100;}
    .nav-inner{max-width:1200px;margin:0 auto;padding:0 28px;height:66px;display:flex;align-items:center;justify-content:space-between;}
    .nav-logo{display:flex;align-items:center;gap:12px;}
    .nav-mark{background:var(--orange);width:32px;height:32px;border-radius:4px;display:flex;align-items:center;justify-content:center;font-family:var(--fh);font-size:0.7rem;font-weight:800;color:#fff;}
    .nav-name{font-family:var(--fh);font-size:0.95rem;font-weight:800;}
    .nav-links{display:flex;gap:28px;list-style:none;}
    .nav-links a{font-size:0.82rem;color:var(--muted);transition:color 0.2s;}
    .nav-links a:hover{color:var(--text);}
    .btn{display:inline-flex;align-items:center;gap:8px;padding:10px 22px;border-radius:4px;font-size:0.82rem;font-weight:700;cursor:pointer;transition:all 0.2s;border:none;font-family:var(--ff);}
    .btn-primary{background:var(--orange);color:#fff;}
    .btn-primary:hover{background:#e06e00;transform:translateY(-1px);}
    .btn-ghost{background:transparent;color:var(--text);border:1px solid var(--border);}
    .btn-ghost:hover{border-color:var(--orange);color:var(--orange);}
    .container{max-width:1200px;margin:0 auto;padding:0 28px;}

    /* HERO */
    #hero{min-height:90vh;display:flex;align-items:center;position:relative;overflow:hidden;padding-top:0;}
    .hero-bg{position:absolute;inset:0;background:linear-gradient(135deg,rgba(11,15,26,1) 50%,rgba(247,127,0,0.06) 100%);}
    .hero-grid{position:absolute;inset:0;background-image:linear-gradient(rgba(247,127,0,0.03) 1px,transparent 1px),linear-gradient(90deg,rgba(247,127,0,0.03) 1px,transparent 1px);background-size:48px 48px;}
    .hero-content{position:relative;z-index:2;max-width:720px;}
    .hero-eyebrow{font-size:0.68rem;letter-spacing:0.22em;text-transform:uppercase;color:var(--orange);margin-bottom:24px;display:flex;align-items:center;gap:12px;}
    .hero-eyebrow::before{content:'';display:block;width:28px;height:1px;background:var(--orange);}
    h1{font-family:var(--fh);font-size:clamp(2.5rem,6vw,4.5rem);font-weight:800;letter-spacing:-0.02em;line-height:1.05;margin-bottom:24px;}
    h1 span{color:var(--orange);}
    .hero-sub{font-size:1.05rem;color:var(--muted);max-width:520px;margin-bottom:40px;line-height:1.75;}
    .hero-actions{display:flex;gap:14px;flex-wrap:wrap;}
    /* PRICE TICKER */
    .price-ticker{background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:20px 28px;margin-top:48px;display:inline-flex;gap:40px;flex-wrap:wrap;}
    .ticker-item{}
    .ticker-label{font-size:0.62rem;text-transform:uppercase;letter-spacing:0.15em;color:var(--muted);margin-bottom:4px;}
    .ticker-price{font-family:var(--fh);font-size:1.4rem;font-weight:800;color:var(--text);}
    .ticker-price span{font-size:0.75rem;color:var(--muted);font-family:var(--ff);font-weight:400;}
    .ticker-date{font-size:0.65rem;color:var(--muted);margin-top:4px;}

    /* SECTIONS */
    section{padding:100px 0;}
    .section-tag{display:inline-block;font-size:0.62rem;letter-spacing:0.2em;text-transform:uppercase;color:var(--orange);border:1px solid rgba(247,127,0,0.3);padding:3px 12px;border-radius:2px;margin-bottom:16px;}
    h2{font-family:var(--fh);font-size:clamp(1.8rem,3.5vw,2.8rem);font-weight:800;letter-spacing:-0.02em;line-height:1.1;margin-bottom:16px;}
    .section-sub{font-size:1rem;color:var(--muted);max-width:520px;margin-bottom:52px;line-height:1.75;}

    /* DUAL AUDIENCE */
    #audiences{background:var(--surface);border-top:1px solid var(--border);}
    .audience-grid{display:grid;grid-template-columns:1fr 1fr;gap:2px;}
    .audience-card{background:var(--bg);padding:56px 48px;border:1px solid var(--border);transition:border-color 0.3s;}
    .audience-card:hover{border-color:rgba(247,127,0,0.3);}
    .audience-icon{font-size:2.5rem;margin-bottom:20px;}
    .audience-title{font-family:var(--fh);font-size:1.4rem;font-weight:800;margin-bottom:12px;}
    .audience-desc{font-size:0.875rem;color:var(--muted);line-height:1.75;margin-bottom:28px;}
    .audience-list{list-style:none;display:flex;flex-direction:column;gap:8px;margin-bottom:32px;}
    .audience-list li{font-size:0.85rem;display:flex;align-items:center;gap:10px;color:var(--muted);}
    .audience-list li::before{content:'→';color:var(--orange);font-size:0.75rem;}

    /* BRANCHES PREVIEW */
    #branches-preview{}
    .branches-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:2px;margin-bottom:36px;}
    .branch-card{background:var(--surface);border:1px solid var(--border);padding:24px 20px;transition:border-color 0.2s;}
    .branch-card:hover{border-color:rgba(247,127,0,0.3);}
    .branch-status-dot{width:8px;height:8px;border-radius:50%;background:var(--green);display:inline-block;margin-right:6px;}
    .branch-status-text{font-size:0.65rem;text-transform:uppercase;letter-spacing:0.1em;color:var(--green);margin-bottom:12px;display:flex;align-items:center;}
    .branch-name{font-family:var(--fh);font-size:0.95rem;font-weight:700;margin-bottom:6px;}
    .branch-loc{font-size:0.75rem;color:var(--muted);}
    .branch-products{display:flex;flex-wrap:wrap;gap:6px;margin-top:12px;}
    .prod-tag{font-size:0.62rem;padding:2px 8px;background:rgba(247,127,0,0.08);border:1px solid rgba(247,127,0,0.2);border-radius:2px;color:var(--muted);}

    /* LPG STRIP */
    #lpg-strip{background:linear-gradient(135deg,var(--surface),rgba(247,127,0,0.05));}
    .lpg-grid{display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:center;}
    .lpg-right{display:flex;flex-direction:column;gap:16px;}
    .lpg-feature{background:var(--bg);border:1px solid var(--border);border-radius:6px;padding:20px 24px;display:flex;align-items:flex-start;gap:16px;}
    .lpg-icon{font-size:1.4rem;flex-shrink:0;}
    .lpg-feat-title{font-weight:700;font-size:0.9rem;margin-bottom:4px;}
    .lpg-feat-desc{font-size:0.8rem;color:var(--muted);line-height:1.6;}

    /* FLEET CTA */
    #fleet-cta{background:var(--surface);border-top:1px solid var(--border);border-bottom:1px solid var(--border);padding:80px 0;}
    .fleet-inner{display:grid;grid-template-columns:1fr auto;gap:60px;align-items:center;}
    .fleet-stat{display:flex;gap:48px;flex-wrap:wrap;}
    .fstat-num{font-family:var(--fh);font-size:2.5rem;font-weight:800;color:var(--orange);}
    .fstat-label{font-size:0.78rem;color:var(--muted);}

    /* TRUST */
    #trust{padding:80px 0;background:var(--bg);border-top:1px solid var(--border);}
    .trust-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:2px;}
    .trust-item{background:var(--surface);border:1px solid var(--border);padding:32px 24px;text-align:center;}
    .trust-icon{font-size:2rem;margin-bottom:12px;}
    .trust-label{font-size:0.85rem;font-weight:600;margin-bottom:6px;}
    .trust-desc{font-size:0.75rem;color:var(--muted);line-height:1.6;}

    /* FOOTER */
    footer{background:var(--surface);border-top:1px solid var(--border);padding:56px 0 32px;}
    .footer-grid{display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:48px;margin-bottom:48px;}
    .footer-brand{font-family:var(--fh);font-size:1rem;font-weight:800;margin-bottom:8px;}
    .footer-tagline{font-size:0.8rem;color:var(--muted);margin-bottom:20px;}
    .footer-emergency{background:rgba(127,29,29,0.3);border:1px solid rgba(127,29,29,0.5);padding:12px 16px;border-radius:4px;font-size:0.75rem;color:#fca5a5;}
    .footer-col-title{font-size:0.65rem;text-transform:uppercase;letter-spacing:0.15em;color:var(--muted);margin-bottom:14px;}
    .footer-links{list-style:none;display:flex;flex-direction:column;gap:8px;}
    .footer-links a{font-size:0.82rem;color:var(--muted);transition:color 0.2s;}
    .footer-links a:hover{color:var(--orange);}
    .footer-bottom{padding-top:24px;border-top:1px solid var(--border);display:flex;justify-content:space-between;font-size:0.75rem;color:var(--muted);}

    @media(max-width:900px){
      .nav-links{display:none;}
      .audience-grid,.lpg-grid,.fleet-inner,.footer-grid{grid-template-columns:1fr;}
      .branches-grid{grid-template-columns:1fr 1fr;}
      .trust-grid{grid-template-columns:1fr 1fr;}
    }
    @media(max-width:600px){
      .branches-grid,.trust-grid{grid-template-columns:1fr;}
    }
  </style>
</head>
<body>

<!-- EMERGENCY -->
<div class="emergency">
  ⚠ LPG emergency or fuel hazard? Call your nearest branch immediately.
  <a href={`${base}/clients/ecopetrol-aurora/contact`}>Branch Hotlines →</a>
</div>

<!-- NAV -->
<nav>
  <div class="nav-inner">
    <a href={`${base}/clients/ecopetrol-aurora/`} class="nav-logo">
      <div class="nav-mark">EC</div>
      <div class="nav-name">· ECOPETROL</div>
    </a>
    <ul class="nav-links">
      <li><a href={`${base}/clients/ecopetrol-aurora/branches`}>Branches</a></li>
      <li><a href={`${base}/clients/ecopetrol-aurora/prices`}>Prices</a></li>
      <li><a href={`${base}/clients/ecopetrol-aurora/lpg`}>LPG / Solane</a></li>
      <li><a href={`${base}/clients/ecopetrol-aurora/fleet`}>Fleet</a></li>
      <li><a href={`${base}/clients/ecopetrol-aurora/about`}>About</a></li>
      <li><a href={`${base}/clients/ecopetrol-aurora/contact`}>Contact</a></li>
    </ul>
    <a href={`${base}/clients/ecopetrol-aurora/fleet`} class="btn btn-primary">Fleet Accounts →</a>
  </div>
</nav>

<!-- HERO -->
<section id="hero">
  <div class="hero-bg"></div>
  <div class="hero-grid"></div>
  <div class="container">
    <div class="hero-content">
      <div class="hero-eyebrow">Aurora Province Fuel Network</div>
      <h1>Fuel That <span>Keeps</span><br/>Aurora Moving.</h1>
      <p class="hero-sub">8 branches across Aurora Province. Gasoline, diesel, and Solane LPG for retail customers, fleet operators, and institutional buyers since 2012.</p>
      <div class="hero-actions">
        <a href={`${base}/clients/ecopetrol-aurora/branches`} class="btn btn-primary">Find a Branch ↗</a>
        <a href={`${base}/clients/ecopetrol-aurora/fleet`} class="btn btn-ghost">Fleet Accounts</a>
      </div>
      <!-- LIVE PRICE TICKER -->
      <div class="price-ticker" id="priceTicker">
        <div class="ticker-item">
          <div class="ticker-label">Unleaded RON 91</div>
          <div class="ticker-price" id="t-ron91">₱89.50 <span>/L</span></div>
          <div class="ticker-date" id="ticker-date">As of today</div>
        </div>
        <div class="ticker-item">
          <div class="ticker-label">Premium RON 95</div>
          <div class="ticker-price" id="t-ron95">₱94.00 <span>/L</span></div>
        </div>
        <div class="ticker-item">
          <div class="ticker-label">Diesel Euro 4</div>
          <div class="ticker-price" id="t-diesel">₱84.50 <span>/L</span></div>
        </div>
        <div class="ticker-item" style="border-left:1px solid var(--border);padding-left:40px;">
          <div class="ticker-label">Full Price Board</div>
          <a href={`${base}/clients/ecopetrol-aurora/prices`} class="btn btn-ghost" style="padding:8px 16px;font-size:0.75rem;margin-top:4px;">View All →</a>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- DUAL AUDIENCE -->
<section id="audiences">
  <div class="container">
    <div class="audience-grid">
      <div class="audience-card">
        <div class="audience-icon">🚗</div>
        <div class="audience-title">For Motorists & Households</div>
        <p class="audience-desc">Find your nearest Ecopetrol station, check today's pump prices, and arrange Solane LPG delivery for your home.</p>
        <ul class="audience-list">
          <li>8 branch locations across Aurora Province</li>
          <li>Daily price board — always current</li>
          <li>Solane LPG cylinders & residential delivery</li>
          <li>Kerosene for household use</li>
        </ul>
        <a href={`${base}/clients/ecopetrol-aurora/branches`} class="btn btn-ghost">Find Your Branch →</a>
      </div>
      <div class="audience-card">
        <div class="audience-icon">🚛</div>
        <div class="audience-title">For Fleets & Institutions</div>
        <p class="audience-desc">Open a fleet account for volume pricing, credit terms, and dedicated service across our Aurora network.</p>
        <ul class="audience-list">
          <li>Volume pricing for fleet operators</li>
          <li>Government & institutional supply capacity</li>
          <li>Commercial LPG delivery for restaurants & resorts</li>
          <li>Multi-branch account coverage</li>
        </ul>
        <a href={`${base}/clients/ecopetrol-aurora/fleet`} class="btn btn-primary">Open Fleet Account →</a>
      </div>
    </div>
  </div>
</section>

<!-- BRANCHES PREVIEW -->
<section id="branches-preview">
  <div class="container">
    <div class="section-tag">Branch Network</div>
    <h2>Across Aurora Province.</h2>
    <p class="section-sub">From Maria Aurora to Baler, Dipaculao to San Luis — we're where Aurora moves.</p>
    <div class="branches-grid" id="branchCards">
      <!-- Rendered by JS from live status -->
    </div>
    <a href={`${base}/clients/ecopetrol-aurora/branches`} class="btn btn-ghost">View All Branches with Maps →</a>
  </div>
</section>

<!-- LPG STRIP -->
<section id="lpg-strip">
  <div class="container">
    <div class="lpg-grid">
      <div>
        <div class="section-tag">Solane LPG</div>
        <h2>Gas Up Your Home<br/>& Business.</h2>
        <p class="section-sub">Authorized Solane showroom. Residential cylinder refills and commercial bulk delivery across Aurora coverage areas.</p>
        <a href={`${base}/clients/ecopetrol-aurora/lpg`} class="btn btn-primary">Schedule LPG Delivery →</a>
      </div>
      <div class="lpg-right">
        <div class="lpg-feature">
          <div class="lpg-icon">🏠</div>
          <div><div class="lpg-feat-title">Residential Refills</div><div class="lpg-feat-desc">11kg and 22kg cylinders. Call your nearest Solane showroom branch to schedule a refill or swap.</div></div>
        </div>
        <div class="lpg-feature">
          <div class="lpg-icon">🏭</div>
          <div><div class="lpg-feat-title">Commercial & Bulk Delivery</div><div class="lpg-feat-desc">For restaurants, resorts, food businesses, and institutional kitchens. Volume pricing available.</div></div>
        </div>
        <div class="lpg-feature">
          <div class="lpg-icon">📦</div>
          <div><div class="lpg-feat-title">Cylinder Availability</div><div class="lpg-feat-desc">Multiple Solane showroom branches across the province. Check your nearest location for current stock.</div></div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- FLEET CTA -->
<section id="fleet-cta">
  <div class="container">
    <div class="fleet-inner">
      <div>
        <div class="section-tag">Fleet & Institutional</div>
        <h2 style="margin-bottom:12px;">Your operations run on fuel.<br/>Ours runs on reliability.</h2>
        <p style="color:var(--muted);font-size:0.95rem;max-width:480px;line-height:1.75;margin-bottom:28px;">Government agencies, construction companies, logistics operators, and resort groups across Aurora trust Ecopetrol for uninterrupted fuel supply.</p>
        <a href={`${base}/clients/ecopetrol-aurora/fleet`} class="btn btn-primary">Apply for a Fleet Account →</a>
      </div>
      <div class="fleet-stat">
        <div><div class="fstat-num">8+</div><div class="fstat-label">Branch locations</div></div>
        <div><div class="fstat-num">4</div><div class="fstat-label">Fuel products</div></div>
        <div><div class="fstat-num">14+</div><div class="fstat-label">Years in Aurora</div></div>
      </div>
    </div>
  </div>
</section>

<!-- TRUST -->
<section id="trust">
  <div class="container">
    <div class="trust-grid">
      <div class="trust-item">
        <div class="trust-icon">⚖️</div>
        <div class="trust-label">DOE Compliant</div>
        <div class="trust-desc">Operating under Department of Energy regulations. Certificates of compliance maintained per branch.</div>
      </div>
      <div class="trust-item">
        <div class="trust-icon">🔒</div>
        <div class="trust-label">Solane Authorized</div>
        <div class="trust-desc">Official Solane LPG showroom operator. Authentic product, certified handling, and safe delivery practices.</div>
      </div>
      <div class="trust-item">
        <div class="trust-icon">📍</div>
        <div class="trust-label">8 Branch Locations</div>
        <div class="trust-desc">The widest fuel network in Aurora Province, spanning 5+ municipalities from coast to mountain barangays.</div>
      </div>
      <div class="trust-item">
        <div class="trust-icon">🤝</div>
        <div class="trust-label">Institutional Supplier</div>
        <div class="trust-desc">Serving government agencies, construction firms, and commercial operators across Aurora Province.</div>
      </div>
    </div>
  </div>
</section>

<!-- FOOTER -->
<footer>
  <div class="container">
    <div class="footer-grid">
      <div>
        <div class="footer-brand">· ECOPETROL AURORA</div>
        <div class="footer-tagline">Fuel and LPG across Aurora Province.</div>
        <div class="footer-emergency">⚠ LPG leak or fuel emergency?<br/>Call your nearest branch immediately.</div>
      </div>
      <div>
        <div class="footer-col-title">For Motorists</div>
        <ul class="footer-links">
          <li><a href={`${base}/clients/ecopetrol-aurora/branches`}>Find a Branch</a></li>
          <li><a href={`${base}/clients/ecopetrol-aurora/prices`}>Fuel Prices</a></li>
          <li><a href={`${base}/clients/ecopetrol-aurora/lpg`}>LPG / Solane</a></li>
        </ul>
      </div>
      <div>
        <div class="footer-col-title">For Business</div>
        <ul class="footer-links">
          <li><a href={`${base}/clients/ecopetrol-aurora/fleet`}>Fleet Accounts</a></li>
          <li><a href={`${base}/clients/ecopetrol-aurora/about`}>About Ecopetrol</a></li>
          <li><a href={`${base}/clients/ecopetrol-aurora/contact`}>Contact Us</a></li>
        </ul>
      </div>
      <div>
        <div class="footer-col-title">Admin</div>
        <ul class="footer-links">
          <li><a href={`${base}/admin/ecopetrol/login.html`}>Operations Portal</a></li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      <span>© 2026 Ecopetrol Gasoline Station · Aurora Province · +63 917 821 4563</span>
      <span>Site by <a href={`${base}/foundry-hq.html`} style="color:var(--orange)">Aurora Digital Foundry</a></span>
    </div>
  </div>
</footer>

<script define:vars={{ SCRIPT_URL }}>
  // Load live prices from Google Sheets (falls back to placeholders)
  const SHEET_ID = '1YSl6At1Gbcg64yTtJmL134YkWnNf26rFxm_Q88EX4GM';
  const PRICES_CSV = `https://docs.google.com/spreadsheets/d/${SHEET_ID}/export?format=csv&gid=0`;

  async function loadPrices() {
    try {
      const res = await fetch(`${SCRIPT_URL}?type=prices`);
      const json = await res.json();
      const latest = json.data && json.data[0];
      if (latest) {
        document.getElementById('t-ron91').innerHTML = `₱${latest.RON91} <span>/L</span>`;
        document.getElementById('t-ron95').innerHTML = `₱${latest.RON95} <span>/L</span>`;
        document.getElementById('t-diesel').innerHTML = `₱${latest.Diesel} <span>/L</span>`;
        const d = new Date(latest.Timestamp);
        document.getElementById('ticker-date').textContent = `Updated ${d.toLocaleDateString('en-PH', {month:'short',day:'numeric'})}`;
      }
    } catch {}
  }

  // Branch cards
  const BRANCHES = [
    { name: 'Maria Aurora — Flagship', loc: 'Maria Aurora, Aurora', products: ['Unleaded','Diesel','Solane LPG'] },
    { name: 'Baler NE', loc: 'Baler, Aurora', products: ['Unleaded','Diesel','Solane LPG'] },
    { name: 'Baler Pingit', loc: 'Baler, Aurora', products: ['Unleaded','Diesel'] },
