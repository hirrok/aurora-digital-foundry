---
import BaseLayout from '../../../layouts/BaseLayout.astro';
const base = '/aurora-digital-foundry/clients/ecopetrol-aurora';
---

<BaseLayout
  title="Fleet Accounts — Ecopetrol Aurora"
  description="Open a fleet or institutional account with Ecopetrol Aurora. Volume fuel supply, credit terms, and multi-branch access across Aurora Province.">

  <Fragment slot="head">
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@600;700;800&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet" />
  </Fragment>

  <style>
    .fd { font-family: 'Barlow Condensed', sans-serif; }
    .fb { font-family: 'DM Sans', sans-serif; }
    :root { --er: #C41E1E; --eg: #1B5E20; --ed: #0F1923; }
    .form-input {
      width: 100%; border: 1px solid #374151; border-radius: 0.375rem;
      padding: 0.625rem 0.875rem; font-size: 0.875rem; background: #1f2937;
      color: #f9fafb; font-family: 'DM Sans', sans-serif;
    }
    .form-input::placeholder { color: #6b7280; }
    .form-input:focus { outline: 2px solid var(--er); outline-offset: 1px; }
    .form-label { display: block; font-size: 0.75rem; font-weight: 700;
      text-transform: uppercase; letter-spacing: 0.1em; color: #9ca3af;
      margin-bottom: 0.375rem; font-family: 'Barlow Condensed', sans-serif; }
  </style>

  <div style="background:var(--er)" class="text-white text-center text-sm py-2 px-4 fd tracking-widest uppercase">
    ⚡ Emergency Hotline: <span class="ml-1 font-bold">TODO — Add branch emergency contact</span>
  </div>

  <nav class="bg-white border-b border-gray-100 sticky top-0 z-50 shadow-sm">
    <div class="max-w-6xl mx-auto px-4 flex items-center justify-between h-16">
      <a href={base + '/'} class="fd text-xl font-black tracking-wider uppercase" style="color:var(--er)">
        ECOPETROL <span class="text-gray-400 font-normal text-sm">AURORA</span>
      </a>
      <div class="hidden md:flex items-center gap-6 text-sm font-medium fb text-gray-700">
        <a href={base + '/branches'} class="hover:text-red-700 transition-colors">Branches</a>
        <a href={base + '/prices'} class="hover:text-red-700 transition-colors">Fuel Prices</a>
        <a href={base + '/lpg'} class="hover:text-red-700 transition-colors">LPG / Solane</a>
        <a href={base + '/fleet'} class="font-bold" style="color:var(--er)">Fleet Accounts</a>
        <a href={base + '/about'} class="hover:text-red-700 transition-colors">About</a>
        <a href={base + '/contact'} style="background:var(--er)" class="text-white px-4 py-2 rounded font-semibold hover:opacity-90 transition-opacity">Contact Us</a>
      </div>
    </div>
  </nav>

  <!-- Hero -->
  <section style="background:var(--ed)" class="text-white py-20 px-4 relative overflow-hidden">
    <div class="absolute inset-0 opacity-10" style="background: repeating-linear-gradient(45deg, var(--er), var(--er) 1px, transparent 1px, transparent 20px)"></div>
    <div class="relative max-w-6xl mx-auto grid md:grid-cols-2 gap-12 items-center">
      <div>
        <p class="fd text-sm tracking-[0.25em] uppercase mb-2" style="color:var(--er)">B2B · Institutional · Government</p>
        <h1 class="fd text-5xl md:text-7xl font-black uppercase leading-tight">POWER<br/>YOUR<br/>FLEET</h1>
        <p class="fb text-gray-300 mt-4 max-w-md">
          Reliable fuel supply for fleets, construction equipment, government vehicles,
          and institutional buyers across Aurora Province.
          Multi-branch access, volume pricing, and credit terms available.
        </p>
      </div>
      <div class="grid grid-cols-2 gap-4">
        {[
          { icon: "🚛", title: "Fleet Operators", desc: "Trucks, buses, delivery vehicles" },
          { icon: "🏗️", title: "Construction", desc: "Equipment and site vehicles" },
          { icon: "🏛️", title: "Government", desc: "LGU, DPWH, agencies" },
          { icon: "🏢", title: "Institutions", desc: "Schools, hospitals, NGOs" }
        ].map(item => (
          <div class="bg-white/10 rounded-lg p-4 border border-white/20">
            <div class="text-2xl mb-2">{item.icon}</div>
            <div class="fd font-bold text-white text-sm uppercase">{item.title}</div>
            <div class="fb text-gray-400 text-xs mt-1">{item.desc}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Benefits Bar -->
  <section style="background:var(--er)" class="text-white py-8 px-4">
    <div class="max-w-6xl mx-auto grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
      {[
        { title: "8+ Branches", sub: "Multi-branch fueling" },
        { title: "Credit Terms", sub: "Volume account options" },
        { title: "Gov Ready", sub: "DPWH supply experience" },
        { title: "LPG Included", sub: "Solane LPG for fleets" }
      ].map(b => (
        <div>
          <div class="fd text-xl font-black">{b.title}</div>
          <div class="fb text-red-200 text-sm mt-0.5">{b.sub}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- Fleet Account Form -->
  <section class="py-16 px-4" style="background:#111827">
    <div class="max-w-3xl mx-auto">
      <div class="mb-10">
        <p class="fd text-sm tracking-[0.2em] uppercase text-gray-400 mb-1">Fleet Account Application</p>
        <h2 class="fd text-4xl font-black text-white uppercase">OPEN YOUR ACCOUNT</h2>
        <p class="fb text-gray-400 mt-2">
          Fill out the form below. Our team will contact you within 2 business days
          to discuss volume, terms, and branch setup.
        </p>
      </div>

      <form action="https://formspree.io/f/TODO-FLEET" method="POST" class="space-y-6">

        <!-- Company Info -->
        <div class="border border-gray-700 rounded-lg p-6">
          <div class="fd text-sm font-bold text-gray-400 uppercase tracking-wider mb-4">Company Information</div>
          <div class="grid md:grid-cols-2 gap-4">
            <div>
              <label class="form-label">Company / Organization Name *</label>
              <input type="text" name="company_name" required placeholder="e.g. Lara Construction Corp." class="form-input" />
            </div>
            <div>
              <label class="form-label">TIN (if applicable)</label>
              <input type="text" name="tin" placeholder="000-000-000-000" class="form-input" />
            </div>
            <div>
              <label class="form-label">Type of Organization *</label>
              <select name="org_type" required class="form-input">
                <option value="">Select type</option>
                <option>Private Company</option>
                <option>Government Agency / LGU</option>
                <option>Construction Company</option>
                <option>Transport / Logistics</option>
                <option>NGO / Institution</option>
                <option>Other</option>
              </select>
            </div>
            <div>
              <label class="form-label">Municipality / Province</label>
              <input type="text" name="location" placeholder="e.g. Maria Aurora, Aurora" class="form-input" />
            </div>
          </div>
        </div>

        <!-- Contact Person -->
        <div class="border border-gray-700 rounded-lg p-6">
          <div class="fd text-sm font-bold text-gray-400 uppercase tracking-wider mb-4">Contact Person</div>
          <div class="grid md:grid-cols-2 gap-4">
            <div>
              <label class="form-label">Full Name *</label>
              <input type="text" name="contact_name" required placeholder="Name and designation" class="form-input" />
            </div>
            <div>
              <label class="form-label">Role / Title</label>
              <input type="text" name="contact_role" placeholder="e.g. Procurement Officer" class="form-input" />
            </div>
            <div>
              <label class="form-label">Phone Number *</label>
              <input type="tel" name="phone" required placeholder="09XX XXX XXXX" class="form-input" />
            </div>
            <div>
              <label class="form-label">Email Address</label>
              <input type="email" name="email" placeholder="procurement@company.com" class="form-input" />
            </div>
          </div>
        </div>

        <!-- Fuel Requirements -->
        <div class="border border-gray-700 rounded-lg p-6">
          <div class="fd text-sm font-bold text-gray-400 uppercase tracking-wider mb-4">Fuel Requirements</div>
          <div class="grid md:grid-cols-2 gap-4">
            <div>
              <label class="form-label">Estimated Fleet Size</label>
              <select name="fleet_size" class="form-input">
                <option value="">Select range</option>
                <option>1–5 vehicles</option>
                <option>6–20 vehicles</option>
                <option>21–50 vehicles</option>
                <option>50+ vehicles</option>
              </select>
            </div>
            <div>
              <label class="form-label">Primary Fuel Type</label>
              <select name="fuel_type" class="form-input">
                <option value="">Select fuel</option>
                <option>Diesel</option>
                <option>Gasoline (RON 91)</option>
                <option>Gasoline (RON 95)</option>
                <option>Mixed</option>
                <option>LPG</option>
              </select>
            </div>
            <div>
              <label class="form-label">Estimated Monthly Volume</label>
              <select name="volume" class="form-input">
                <option value="">Select range</option>
                <option>Below 500L/month</option>
                <option>500–2,000L/month</option>
                <option>2,000–10,000L/month</option>
                <option>10,000L+/month</option>
              </select>
            </div>
            <div>
              <label class="form-label">Preferred Branch(es)</label>
              <input type="text" name="preferred_branch" placeholder="e.g. Maria Aurora Main, Baler NE" class="form-input" />
            </div>
          </div>
        </div>

        <!-- Billing -->
        <div class="border border-gray-700 rounded-lg p-6">
          <div class="fd text-sm font-bold text-gray-400 uppercase tracking-wider mb-4">Billing Preference</div>
          <div class="grid md:grid-cols-2 gap-4">
            <div>
              <label class="form-label">Preferred Billing Cycle</label>
              <select name="billing" class="form-input">
                <option>Weekly</option>
                <option>Bi-weekly</option>
                <option>Monthly</option>
                <option>Per transaction (no credit)</option>
              </select>
            </div>
            <div>
              <label class="form-label">Additional Notes</label>
              <textarea name="notes" rows="3" placeholder="Special requirements, delivery needs, etc." class="form-input"></textarea>
            </div>
          </div>
        </div>

        <input type="hidden" name="_subject" value="Fleet Account Application — Ecopetrol Aurora" />
        <button type="submit" style="background:var(--er)" class="w-full text-white fd font-black text-xl py-4 uppercase tracking-widest hover:opacity-90 transition-opacity rounded">
          SUBMIT APPLICATION
        </button>
        <p class="fb text-xs text-gray-600 text-center">
          Our team will respond within 2 business days. · TODO: Replace Formspree ID before going live.
        </p>
      </form>

      <!-- Procurement Note -->
      <div class="mt-10 border border-gray-700 rounded-lg p-6">
        <div class="fd text-sm font-bold text-gray-400 uppercase tracking-wider mb-3">Government & Procurement Officers</div>
        <p class="fb text-gray-400 text-sm mb-4">
          Ecopetrol Aurora has experience supplying fuel to government procurement accounts in Aurora Province,
          including district engineering office requirements. A capability statement is available upon request.
        </p>
        <a href={base + '/contact'}
           class="inline-block border border-gray-600 text-gray-300 fd font-bold text-sm px-5 py-2 uppercase tracking-wide hover:border-red-500 hover:text-white transition-colors rounded">
          REQUEST CAPABILITY STATEMENT →
        </a>
        <p class="fb text-xs text-gray-600 mt-2">TODO: Confirm DPWH supply history with client before inserting specifics</p>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer style="background:var(--ed)" class="text-gray-400 pt-10 pb-6">
    <div class="max-w-6xl mx-auto px-4">
      <div class="flex flex-col md:flex-row items-center justify-between text-sm fb">
        <div class="fd text-lg font-black text-white mb-2 md:mb-0">ECOPETROL <span style="color:var(--er)">AURORA</span></div>
        <div class="flex gap-6 text-gray-500">
          <a href={base + '/'} class="hover:text-white transition-colors">Home</a>
          <a href={base + '/branches'} class="hover:text-white transition-colors">Branches</a>
          <a href={base + '/lpg'} class="hover:text-white transition-colors">LPG</a>
          <a href={base + '/contact'} class="hover:text-white transition-colors">Contact</a>
        </div>
      </div>
      <div class="border-t border-gray-800 mt-6 pt-4 text-xs text-center text-gray-600 fb">
        © 2026 Ecopetrol Aurora · Site by <a href="https://github.com/hirrok" class="hover:text-white">Aurora Digital Foundry</a>
      </div>
    </div>
  </footer>

</BaseLayout>
