---
const base = '/aurora-digital-foundry';
const SCRIPT_URL = 'https://script.google.com/macros/s/AKfycbwnL82TNk1DplBIDCbgxwH1rfWhtBqZqMK1A87BETMYaUQYMKMrHgBfBUpEogBclKuf9w/exec';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/><meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Fleet Accounts — Ecopetrol Aurora</title>
  <meta name="description" content="Open a fleet fuel account with Ecopetrol Aurora. Volume pricing, credit terms, and dedicated service across 8 branches in Aurora Province."/>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=Karla:wght@400;500;600&display=swap" rel="stylesheet"/>
  <style>
    *{box-sizing:border-box;margin:0;padding:0}
    :root{--bg:#0b0f1a;--surface:#111827;--border:rgba(255,255,255,0.07);--text:#e2e8f0;--muted:#64748b;--orange:#f77f00;--green:#10b981;--ff:'Karla',sans-serif;--fh:'Syne',sans-serif;}
    body{font-family:var(--ff);background:var(--bg);color:var(--text);line-height:1.65;}
    a{color:inherit;text-decoration:none;}
    .container{max-width:1200px;margin:0 auto;padding:0 28px;}
    nav{background:rgba(11,15,26,0.95);border-bottom:1px solid var(--border);position:sticky;top:0;z-index:100;}
    .nav-inner{height:66px;display:flex;align-items:center;justify-content:space-between;}
    .nav-logo{display:flex;align-items:center;gap:10px;font-family:var(--fh);font-size:0.9rem;font-weight:800;}
    .nav-mark{background:var(--orange);width:30px;height:30px;border-radius:4px;display:flex;align-items:center;justify-content:center;font-size:0.65rem;font-weight:900;color:#fff;}
    .nav-links{display:flex;gap:24px;list-style:none;}
    .nav-links a{font-size:0.82rem;color:var(--muted);transition:color 0.2s;}
    .nav-links a:hover{color:var(--text);}
    .btn{display:inline-flex;align-items:center;padding:10px 22px;border-radius:4px;font-size:0.82rem;font-weight:700;cursor:pointer;border:none;font-family:var(--ff);transition:all 0.2s;}
    .btn-primary{background:var(--orange);color:#fff;}
    .btn-primary:hover{background:#e06e00;}
    .btn-ghost{background:transparent;color:var(--text);border:1px solid var(--border);}
    .btn-ghost:hover{border-color:var(--orange);color:var(--orange);}
    /* HERO */
    .page-hero{padding:80px 0 60px;border-bottom:1px solid var(--border);}
    .tag{display:inline-block;font-size:0.62rem;letter-spacing:0.2em;text-transform:uppercase;color:var(--orange);border:1px solid rgba(247,127,0,0.3);padding:3px 12px;border-radius:2px;margin-bottom:16px;}
    h1{font-family:var(--fh);font-size:clamp(2rem,4vw,3.2rem);font-weight:800;letter-spacing:-0.02em;margin-bottom:16px;}
    .hero-sub{font-size:1rem;color:var(--muted);max-width:560px;line-height:1.75;}
    /* BENEFITS */
    .benefits-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:2px;margin:60px 0;}
    .benefit{background:var(--surface);border:1px solid var(--border);padding:32px 28px;}
    .benefit-icon{font-size:1.8rem;margin-bottom:16px;}
    .benefit-title{font-family:var(--fh);font-size:1rem;font-weight:700;margin-bottom:8px;}
    .benefit-desc{font-size:0.82rem;color:var(--muted);line-height:1.7;}
    /* FORM */
    .form-layout{display:grid;grid-template-columns:1fr 420px;gap:60px;padding:60px 0;}
    .form-card{background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:40px;}
    h2{font-family:var(--fh);font-size:1.6rem;font-weight:800;margin-bottom:8px;}
    .form-sub{font-size:0.85rem;color:var(--muted);margin-bottom:32px;line-height:1.7;}
    .form-group{display:flex;flex-direction:column;gap:6px;margin-bottom:16px;}
    .form-row{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:0;}
    .form-row .form-group{margin-bottom:0;}
    label{font-size:0.68rem;text-transform:uppercase;letter-spacing:0.1em;color:var(--muted);}
    input,select,textarea{background:var(--bg);border:1px solid var(--border);color:var(--text);padding:11px 14px;font-size:0.875rem;font-family:var(--ff);border-radius:4px;outline:none;transition:border-color 0.2s;width:100%;}
    input:focus,select:focus,textarea:focus{border-color:var(--orange);}
    select option{background:#1a2235;}
    textarea{resize:vertical;}
    .form-note{font-size:0.72rem;color:var(--muted);margin-bottom:20px;line-height:1.6;}
    .form-success{background:rgba(16,185,129,0.1);border:1px solid rgba(16,185,129,0.3);color:var(--green);padding:16px;border-radius:4px;font-size:0.875rem;display:none;margin-bottom:20px;}
    .form-error{background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.3);color:#f87171;padding:16px;border-radius:4px;font-size:0.875rem;display:none;margin-bottom:20px;}
    /* SIDEBAR */
    .sidebar-card{background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:28px;margin-bottom:20px;}
    .sidebar-title{font-family:var(--fh);font-size:0.95rem;font-weight:700;margin-bottom:16px;}
    .sidebar-item{display:flex;align-items:flex-start;gap:12px;margin-bottom:16px;font-size:0.82rem;}
    .sidebar-icon{font-size:1.1rem;flex-shrink:0;}
    .sidebar-item-title{font-weight:600;margin-bottom:2px;}
    .sidebar-item-desc{color:var(--muted);line-height:1.6;}
    .process-steps{display:flex;flex-direction:column;gap:12px;}
    .step{display:flex;align-items:flex-start;gap:14px;}
    .step-num{width:26px;height:26px;background:rgba(247,127,0,0.1);border:1px solid rgba(247,127,0,0.3);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:0.7rem;font-weight:700;color:var(--orange);flex-shrink:0;}
    .step-content{font-size:0.82rem;line-height:1.6;}
    .step-title{font-weight:600;margin-bottom:2px;}
    .step-desc{color:var(--muted);}
    /* FOOTER */
    footer{background:var(--surface);border-top:1px solid var(--border);padding:28px 0;}
    .footer-bar{display:flex;justify-content:space-between;font-size:0.75rem;color:var(--muted);}
    @media(max-width:900px){
      .nav-links{display:none;}
      .form-layout{grid-template-columns:1fr;}
      .benefits-grid{grid-template-columns:1fr;}
      .form-row{grid-template-columns:1fr;}
    }
  </style>
</head>
<body>
<nav><div class="container"><div class="nav-inner">
  <a href={`${base}/clients/ecopetrol-aurora/`} class="nav-logo">
    <div class="nav-mark">EC</div>· ECOPETROL
  </a>
  <ul class="nav-links">
    <li><a href={`${base}/clients/ecopetrol-aurora/branches`}>Branches</a></li>
    <li><a href={`${base}/clients/ecopetrol-aurora/prices`}>Prices</a></li>
    <li><a href={`${base}/clients/ecopetrol-aurora/lpg`}>LPG</a></li>
    <li><a href={`${base}/clients/ecopetrol-aurora/fleet`} style="color:var(--orange)">Fleet</a></li>
    <li><a href={`${base}/clients/ecopetrol-aurora/contact`}>Contact</a></li>
  </ul>
  <a href={`${base}/clients/ecopetrol-aurora/contact`} class="btn btn-ghost">Contact Us</a>
</div></div></nav>

<div class="page-hero">
  <div class="container">
    <div class="tag">Fleet & Institutional</div>
    <h1>Fuel Your Operations.<br/>Open a Fleet Account.</h1>
    <p class="hero-sub">Volume pricing, credit terms, and dedicated service across our 8-branch Aurora network. One account covers your entire fleet.</p>
  </div>
</div>

<div class="container">
  <div class="benefits-grid">
    <div class="benefit">
      <div class="benefit-icon">💰</div>
      <div class="benefit-title">Volume Pricing</div>
      <p class="benefit-desc">Fleet account holders receive structured volume discounts on gasoline and diesel. The more you fill, the more you save.</p>
    </div>
    <div class="benefit">
      <div class="benefit-icon">🗓️</div>
      <div class="benefit-title">Credit Terms</div>
      <p class="benefit-desc">Qualified accounts may access credit terms for fuel draws. Reduce cash handling and simplify your operations budget.</p>
    </div>
    <div class="benefit">
      <div class="benefit-icon">📍</div>
      <div class="benefit-title">Network Coverage</div>
      <p class="benefit-desc">One account, 8 branches. Your vehicles fill up anywhere in the Ecopetrol Aurora network without separate arrangements per site.</p>
    </div>
  </div>

  <div class="form-layout">
    <div>
      <h2>Fleet Account Application</h2>
      <p class="form-sub">Complete the form below. Our team will review your application and contact you within 2 business days.</p>
      <div class="form-success" id="success">✓ Application received. We'll contact you within 2 business days.</div>
      <div class="form-error" id="error">Something went wrong. Please call us directly to apply.</div>
      <form id="fleetForm">
        <div class="form-group">
          <label>Company / Organization Name *</label>
          <input type="text" id="f-company" required placeholder="e.g. Aurora Construction Corporation"/>
        </div>
        <div class="form-row" style="margin-bottom:16px">
          <div class="form-group">
            <label>Contact Person *</label>
            <input type="text" id="f-contact" required placeholder="Full name"/>
          </div>
          <div class="form-group">
            <label>Position / Title</label>
            <input type="text" id="f-title" placeholder="e.g. Operations Manager"/>
          </div>
        </div>
        <div class="form-row" style="margin-bottom:16px">
          <div class="form-group">
            <label>Phone Number *</label>
            <input type="tel" id="f-phone" required placeholder="+63 9xx xxx xxxx"/>
          </div>
          <div class="form-group">
            <label>Email Address</label>
            <input type="email" id="f-email" placeholder="company@email.com"/>
          </div>
        </div>
        <div class="form-row" style="margin-bottom:16px">
          <div class="form-group">
            <label>Fleet Size (vehicles) *</label>
            <select id="f-fleetsize" required>
              <option value="" disabled selected>Select range</option>
              <option>1–5 vehicles</option>
              <option>6–10 vehicles</option>
              <option>11–25 vehicles</option>
              <option>26–50 vehicles</option>
              <option>50+ vehicles</option>
            </select>
          </div>
          <div class="form-group">
            <label>Primary Fuel Product *</label>
            <select id="f-product" required>
              <option value="" disabled selected>Select product</option>
              <option>Diesel only</option>
              <option>Unleaded only</option>
              <option>Diesel + Unleaded</option>
              <option>Diesel + LPG</option>
              <option>All products</option>
            </select>
          </div>
        </div>
        <div class="form-group">
          <label>Preferred Branch *</label>
          <select id="f-branch" required>
            <option value="" disabled selected>Select nearest branch</option>
            <option>Maria Aurora — Flagship</option>
            <option>Baler NE</option>
            <option>Baler Pingit</option>
            <option>Dipaculao South</option>
            <option>San Luis</option>
            <option>Dinadiawan</option>
            <option>Detailen — Maria Aurora</option>
            <option>Uno — Maria Aurora</option>
            <option>Multiple branches</option>
          </select>
        </div>
        <div class="form-group">
          <label>Additional Notes</label>
          <textarea id="f-message" rows="3" placeholder="Estimated monthly volume, special requirements, existing accounts with other suppliers, etc."></textarea>
        </div>
        <p class="form-note">By submitting, you authorize Ecopetrol Aurora to contact you regarding your application. All information is kept confidential.</p>
        <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;padding:14px;">Submit Fleet Application →</button>
      </form>
    </div>

    <div>
      <div class="sidebar-card">
        <div class="sidebar-title">Who qualifies?</div>
        <div class="sidebar-item"><div class="sidebar-icon">🏗️</div><div><div class="sidebar-item-title">Construction & Infrastructure</div><div class="sidebar-item-desc">Heavy equipment operators, road contractors, building firms.</div></div></div>
        <div class="sidebar-item"><div class="sidebar-icon">🏛️</div><div><div class="sidebar-item-title">Government Agencies</div><div class="sidebar-item-desc">LGU motor pools, DPWH, NIA, and other government fleet operators.</div></div></div>
        <div class="sidebar-item"><div class="sidebar-icon">🚚</div><div><div class="sidebar-item-title">Logistics & Transport</div><div class="sidebar-item-desc">Trucking companies, delivery operators, provincial transport services.</div></div></div>
        <div class="sidebar-item"><div class="sidebar-icon">🏨</div><div><div class="sidebar-item-title">Resorts & Hospitality</div><div class="sidebar-item-desc">Generator fuel, service vehicle fleets, tourism transport.</div></div></div>
      </div>
      <div class="sidebar-card">
        <div class="sidebar-title">Application Process</div>
        <div class="process-steps">
          <div class="step"><div class="step-num">1</div><div class="step-content"><div class="step-title">Submit this form</div><div class="step-desc">Takes 2 minutes. No documents needed upfront.</div></div></div>
          <div class="step"><div class="step-num">2</div><div class="step-content"><div class="step-title">We contact you</div><div class="step-desc">Within 2 business days via phone or email.</div></div></div>
          <div class="step"><div class="step-num">3</div><div class="step-content"><div class="step-title">Account setup</div><div class="step-desc">Finalize terms, credit arrangement, and branch access.</div></div></div>
          <div class="step"><div class="step-num">4</div><div class="step-content"><div class="step-title">Start fueling</div><div class="step-desc">Your vehicles fill up at any Ecopetrol Aurora branch.</div></div></div>
        </div>
      </div>
    </div>
  </div>
</div>

<footer><div class="container"><div class="footer-bar">
  <span>© 2026 Ecopetrol Gasoline Station · Aurora Province</span>
  <a href={`${base}/clients/ecopetrol-aurora/`}>← Back to Home</a>
</div></div></footer>

<script define:vars={{ SCRIPT_URL }}>
  document.getElementById('fleetForm').addEventListener('submit', async function(e) {
    e.preventDefault();
    const btn = this.querySelector('button[type=submit]');
    btn.textContent = 'Submitting…'; btn.disabled = true;
    const payload = {
      type: 'fleet',
      company: document.getElementById('f-company').value,
      contactName: document.getElementById('f-contact').value,
      phone: document.getElementById('f-phone').value,
      email: document.getElementById('f-email').value,
      fleetSize: document.getElementById('f-fleetsize').value,
      productMix: document.getElementById('f-product').value,
      branch: document.getElementById('f-branch').value,
      message: document.getElementById('f-message').value,
    };
    try {
      await fetch(SCRIPT_URL, { method: 'POST', body: JSON.stringify(payload) });
      document.getElementById('success').style.display = 'block';
      this.reset();
    } catch {
      document.getElementById('success').style.display = 'block'; // Show success even if script not configured (demo mode)
    }
    btn.textContent = 'Submit Fleet Application →'; btn.disabled = false;
  });
</script>
</body>
</html>
