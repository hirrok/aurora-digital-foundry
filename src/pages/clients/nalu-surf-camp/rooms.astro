          <div class="room-rate-block">
            <div class="room-rate-label">Rate per night</div>
            <div class="room-rate-value">TODO: Add rate — placeholder only</div>
          </div>
          <a href={base + "/contact"} class="btn-sm">Inquire Now</a>
        </div>
      </div>

      <div class="room-card">
        <img src="https://images.unsplash.com/photo-1520250497591-112f2f40a3f4?auto=format&fit=crop&w=800&q=75" alt="Ifugao Nipa Hut" class="room-img" loading="lazy" />
