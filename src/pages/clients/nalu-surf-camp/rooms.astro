</section>

<div class="includes-strip">
  <div class="includes-inner">
    <h2 class="includes-heading">Every stay includes:</h2>
    <div class="includes-grid">
      <div class="include-item">
        <span class="include-icon">🥞</span>
        <div class="include-text"><strong>Free Breakfast</strong><span>Daily · 7:30–10AM</span></div>
