      <div class="include-item">
        <span class="include-icon">📶</span>
        <div class="include-text"><strong>Free WiFi</strong><span>Throughout the camp</span></div>
      </div>
      <div class="include-item">
        <span class="include-icon">🅿️</span>
        <div class="include-text"><strong>Free Parking</strong><span>On-site, secure</span></div>
      </div>
      <div class="include-item">
        <span class="include-icon">🔥</span>
        <div class="include-text"><strong>Nightly Bonfire</strong><span>Every night, no charge</span></div>
      </div>
      <div class="include-item">
        <span class="include-icon">🏊</span>
        <div class="include-text"><strong>Pool Access</strong><span>Freshwater, on-site</span></div>
      </div>
      <div class="include-item">
        <span class="include-icon">🎵</span>
        <div class="include-text"><strong>Acoustic Nights</strong><span>Live sessions at camp</span></div>
      </div>
