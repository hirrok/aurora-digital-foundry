---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const client = {
  name: "Nalu Surf Camp",
  address: "57A Labasin St., Brgy. Sabang, Baler, Aurora",
  phone: "+63 917 817 2606",
  hours: "Check-in 14:00 · Check-out 12:00 · Front Desk 24hrs",
  facebook: "https://facebook.com/NaluSurfCamp",
  messenger: "https://m.me/NaluSurfCamp",
  slug: "nalu-surf-camp",
};

const rooms = [
  {
    name: "Premier Nipa Hut — Sea View",
    img: "https://images.unsplash.com/photo-1520250497591-112f2f40a3f4?auto=format&fit=crop&w=900&q=80",
    description: "The best seat in the house. Wake up to the Pacific and fall asleep to the sound of waves. Perfect for couples or small groups looking for the full Baler experience.",
    amenities: ["Ocean-facing view", "Air conditioning", "Private bathroom", "Hot water", "Free WiFi", "Complimentary breakfast"],
    badge: "Most Popular",
  },
  {
    name: "Premier Nipa Hut — Garden View",
    img: "https://images.unsplash.com/photo-1588880331179-bc9b93a8cb5e?auto=format&fit=crop&w=900&q=80",
    description: "Lush garden setting with native nipa architecture. Quiet, breezy, and beautifully designed. Great for couples and families who want comfort with a local touch.",
    amenities: ["Garden view", "Air conditioning", "Private bathroom", "Hot water", "Free WiFi", "Complimentary breakfast"],
    badge: null,
  },
  {
    name: "Ifugao Nipa Hut",
    img: "https://images.unsplash.com/photo-1586375300773-8384e3e4916f?auto=format&fit=crop&w=900&q=80",
    description: "Heritage-inspired design that pays tribute to Ifugao craftsmanship. A unique stay with character. Great for families and groups traveling together.",
    amenities: ["Ifugao heritage design", "Fan / Air conditioning options", "Private bathroom", "Free WiFi", "Complimentary breakfast"],
    badge: null,
  },
  {
    name: "Modern Nipa Hut",
    img: "https://images.unsplash.com/photo-1631049307264-da0ec9d70304?auto=format&fit=crop&w=900&q=80",
    description: "Native materials with modern comforts. Clean lines, practical layout, and the same great beachside atmosphere. A solid choice for any type of traveler.",
    amenities: ["Modern native design", "Air conditioning", "Private bathroom", "Hot water", "Free WiFi", "Complimentary breakfast"],
    badge: null,
  },
  {
    name: "Traditional Nipa Hut",
    img: "https://images.unsplash.com/photo-1566073771259-6a8506099945?auto=format&fit=crop&w=900&q=80",
    description: "Classic kubo living at Sabang Beach. Honest, affordable, and full of character. The choice of surfers who want the real local experience without the frills.",
    amenities: ["Classic kubo style", "Fan ventilation", "Shared or private bathroom", "Free WiFi", "Complimentary breakfast"],
    badge: "Best Value",
  },
  {
    name: "Hammock Area",
    img: "https://images.unsplash.com/photo-1555854877-bab0e564b8d5?auto=format&fit=crop&w=900&q=80",
    description: "The most Baler way to stay. Sling your hammock, feel the ocean breeze, and fall asleep under the stars. Budget-friendly and totally social.",
    amenities: ["Hammock setup", "Open-air", "Shared facilities", "Free WiFi", "Communal bonfire access"],
    badge: "Budget Pick",
  },
];
---

<BaseLayout
  title="Rooms — Nalu Surf Camp | Baler, Aurora"
  description="26 rooms at Nalu Surf Camp — Premier Sea View, Garden View, Ifugao, Modern, and Traditional Nipa Huts, plus Hammock Area. 57A Labasin St., Sabang Beach, Baler."
  client={client}
>

  <section class="page-hero container">
    <p class="eyebrow">Accommodation</p>
    <h1>Rooms & Rates</h1>
    <p class="page-sub">
      26 rooms at Sabang Beach. All rooms designed for the beach lifestyle —<br />
      native architecture, real comfort, and steps from the surf.
    </p>
    <p class="todo-notice">⚠ Rates below are placeholders — TODO: update with real rates before conversion.</p>
  </section>

  <section class="rooms-list container">
    {rooms.map((room) => (
      <div class="room-card">
        <div class="room-card__img-wrap">
          <img src={room.img} alt={room.name} />
          {room.badge && <span class="room-card__badge">{room.badge}</span>}
        </div>
        <div class="room-card__body">
          <h2>{room.name}</h2>
          <p class="room-card__desc">{room.description}</p>
          <ul class="amenities">
            {room.amenities.map((a) => (
              <li>✓ {a}</li>
            ))}
          </ul>
          <div class="room-card__footer">
            <p class="rate todo">TODO: Add rate — placeholder</p>
            <a href={`/aurora-digital-foundry/clients/${client.slug}/contact`} class="btn btn--primary">Inquire / Book</a>
          </div>
        </div>
      </div>
    ))}
  </section>

  <section class="group-cta container">
    <div class="group-cta__inner">
      <h2>Group Bookings?</h2>
      <p>
        Nalu welcomes surf groups, barkada trips, family reunions, and corporate retreats.
        Contact us directly for group rates and package deals.
      </p>
      <a href={`/aurora-digital-foundry/clients/${client.slug}/contact`} class="btn btn--primary">Contact for Group Rates</a>
    </div>
  </section>

</BaseLayout>

<style>
.container { max-width: 1100px; margin: 0 auto; padding: 4rem 1.5rem; }
.eyebrow { color: #0ea5e9; font-size: .8rem; font-weight: 700; letter-spacing: .12em; text-transform: uppercase; margin: 0 0 .4rem; }
.page-hero h1 { font-size: clamp(2rem, 5vw, 3rem); font-weight: 900; margin: 0 0 .75rem; }
.page-sub { color: #64748b; font-size: 1rem; line-height: 1.65; margin: 0 0 1rem; }
.todo-notice { background: #fefce8; border: 1px solid #fbbf24; color: #92400e; border-radius: 6px; padding: .6rem 1rem; font-size: .85rem; display: inline-block; }

.btn { display: inline-block; padding: .75rem 1.75rem; border-radius: 6px; font-weight: 700; font-size: .95rem; text-decoration: none; transition: opacity .15s; }
.btn:hover { opacity: .85; }
.btn--primary { background: #0ea5e9; color: #fff; }

/* ROOM CARDS */
.rooms-list { padding-top: 1rem; }
.room-card {
  display: grid;
  grid-template-columns: 380px 1fr;
  gap: 0;
  border-radius: 12px;
  overflow: hidden;
  box-shadow: 0 2px 12px rgba(0,0,0,.09);
  background: #fff;
  margin-bottom: 2rem;
}
.room-card__img-wrap { position: relative; }
.room-card__img-wrap img { width: 100%; height: 100%; object-fit: cover; min-height: 260px; }
.room-card__badge {
  position: absolute; top: 1rem; left: 1rem;
  background: #0ea5e9; color: #fff;
  font-size: .75rem; font-weight: 700;
  padding: .3rem .75rem; border-radius: 20px;
  letter-spacing: .05em; text-transform: uppercase;
}
.room-card__body { padding: 2rem; }
.room-card__body h2 { font-size: 1.3rem; font-weight: 900; margin: 0 0 .6rem; }
.room-card__desc { color: #475569; font-size: .95rem; line-height: 1.65; margin: 0 0 1.25rem; }

.amenities { list-style: none; padding: 0; margin: 0 0 1.5rem; display: grid; grid-template-columns: 1fr 1fr; gap: .3rem .5rem; }
.amenities li { font-size: .87rem; color: #334155; }

.room-card__footer { display: flex; align-items: center; gap: 1.5rem; flex-wrap: wrap; }
.rate { font-weight: 700; font-size: 1rem; margin: 0; }
.todo { color: #f59e0b; font-style: italic; font-size: .88rem; }

/* GROUP CTA */
.group-cta { padding-top: 0; }
.group-cta__inner {
  background: #f0f9ff;
  border: 1px solid #bae6fd;
  border-radius: 12px;
  padding: 2.5rem;
  text-align: center;
}
.group-cta__inner h2 { font-size: 1.6rem; font-weight: 900; margin: 0 0 .75rem; }
.group-cta__inner p { color: #475569; line-height: 1.65; margin: 0 0 1.5rem; }

/* RESPONSIVE */
@media (max-width: 768px) {
  .room-card { grid-template-columns: 1fr; }
  .room-card__img-wrap img { min-height: 220px; }
  .amenities { grid-template-columns: 1fr; }
}
</style>
