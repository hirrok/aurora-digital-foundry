---
// Nalu Surf Camp — Rooms
const title = "Rooms — Nalu Surf Camp · Baler, Aurora";
const description = "26 nipa hut rooms at Nalu Surf Camp — Traditional, Modern, Ifugao, Premier Garden View, Premier Sea View, and Hammock Area. Brgy. Sabang, Baler.";
const base = "/aurora-digital-foundry/clients/nalu-surf-camp";
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --earth: #2C1F14; --bark: #4A2E1A; --amber: #C4822A; --gold: #E8A94A;
      --sand: #F2E8D5; --salt: #FAF6EE; --ash: #8C7B6B; --wave: #2E5F6B; --foam: #FFFFFF;
      --serif: 'Playfair Display', Georgia, serif; --sans: 'DM Sans', system-ui, sans-serif;
    }
    html { scroll-behavior: smooth; }
    body { font-family: var(--sans); background: var(--salt); color: var(--earth); font-size: 16px; line-height: 1.6; }
    nav {
      position: sticky; top: 0; z-index: 100;
      display: flex; align-items: center; justify-content: space-between;
      padding: 1.25rem 2rem;
      background: rgba(44, 31, 20, 0.96); backdrop-filter: blur(12px);
    }
    .nav-brand { font-family: var(--serif); font-size: 1.1rem; font-weight: 900; color: var(--gold); text-decoration: none; }
    .nav-links { display: flex; gap: 2rem; list-style: none; align-items: center; }
    .nav-links a { color: var(--sand); text-decoration: none; font-size: 0.85rem; font-weight: 500; letter-spacing: 0.06em; text-transform: uppercase; opacity: 0.85; transition: opacity 0.2s; }
    .nav-links a:hover { opacity: 1; color: var(--gold); }
    .nav-cta { background: var(--amber) !important; color: var(--foam) !important; padding: 0.5rem 1.25rem !important; border-radius: 2px; opacity: 1 !important; }
    .nav-toggle { display: none; background: none; border: none; cursor: pointer; }
    .hamburger { display: flex; flex-direction: column; gap: 5px; }
    .hamburger span { display: block; width: 24px; height: 2px; background: var(--sand); border-radius: 2px; }

    .page-hero {
      background: var(--earth); padding: 5rem 2rem 4rem;
      border-bottom: 1px solid rgba(196, 130, 42, 0.2);
    }
    .page-hero-inner { max-width: 1100px; margin: 0 auto; }
    .page-eyebrow { display: inline-block; font-size: 0.75rem; font-weight: 500; letter-spacing: 0.14em; text-transform: uppercase; color: var(--gold); margin-bottom: 1rem; }
    .page-title { font-family: var(--serif); font-size: clamp(2.5rem, 5vw, 4rem); font-weight: 900; color: var(--foam); line-height: 1.1; margin-bottom: 1rem; }
    .page-title em { font-style: italic; color: var(--gold); }
    .page-sub { font-size: 1rem; color: rgba(242,232,213,0.7); max-width: 560px; line-height: 1.7; }

    .rooms-section { padding: 5rem 2rem; }
    .rooms-inner { max-width: 1100px; margin: 0 auto; }

    .rooms-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 2rem; }

    .room-card { background: var(--foam); border-radius: 4px; overflow: hidden; border: 1px solid rgba(74,46,26,0.1); transition: transform 0.25s, box-shadow 0.25s; }
    .room-card:hover { transform: translateY(-4px); box-shadow: 0 12px 40px rgba(44,31,20,0.1); }
    .room-img { width: 100%; aspect-ratio: 4/3; object-fit: cover; display: block; }
    .room-body { padding: 1.75rem; }
    .room-type { font-size: 0.72rem; font-weight: 500; letter-spacing: 0.12em; text-transform: uppercase; color: var(--amber); margin-bottom: 0.4rem; }
    .room-name { font-family: var(--serif); font-size: 1.3rem; font-weight: 700; color: var(--earth); margin-bottom: 0.75rem; }
    .room-features { font-size: 0.88rem; color: var(--ash); margin-bottom: 1rem; line-height: 1.7; }
    .room-amenities { display: flex; flex-wrap: wrap; gap: 0.4rem; margin-bottom: 1.25rem; }
    .amenity-tag { background: rgba(44,31,20,0.06); color: var(--bark); font-size: 0.72rem; padding: 0.25rem 0.65rem; border-radius: 100px; font-weight: 500; }
    .room-rate-block { background: rgba(196,130,42,0.08); border: 1px solid rgba(196,130,42,0.2); border-radius: 3px; padding: 0.75rem 1rem; margin-bottom: 1.25rem; }
    .room-rate-label { font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--amber); margin-bottom: 0.2rem; }
    .room-rate-value { font-family: var(--serif); font-size: 1rem; font-weight: 700; color: var(--earth); font-style: italic; }
    .btn-sm { display: inline-block; background: var(--earth); color: var(--sand); text-decoration: none; padding: 0.65rem 1.4rem; font-size: 0.8rem; font-weight: 500; letter-spacing: 0.07em; text-transform: uppercase; border-radius: 2px; transition: background 0.2s; }
    .btn-sm:hover { background: var(--bark); }

    .includes-strip { background: var(--earth); padding: 3.5rem 2rem; }
    .includes-inner { max-width: 1100px; margin: 0 auto; }
    .includes-heading { font-family: var(--serif); font-size: 1.5rem; font-weight: 700; color: var(--gold); margin-bottom: 2rem; }
    .includes-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 1.25rem; }
    .include-item { display: flex; gap: 0.75rem; align-items: flex-start; }
    .include-icon { font-size: 1.3rem; flex-shrink: 0; }
    .include-text strong { display: block; font-size: 0.88rem; font-weight: 500; color: var(--sand); }
    .include-text span { font-size: 0.8rem; color: rgba(242,232,213,0.55); }

    .cta-strip { background: var(--sand); padding: 4rem 2rem; text-align: center; }
    .cta-strip h2 { font-family: var(--serif); font-size: 2rem; font-weight: 900; color: var(--earth); margin-bottom: 1rem; }
    .cta-strip p { color: var(--ash); margin-bottom: 2rem; max-width: 480px; margin-left: auto; margin-right: auto; }
    .btn-primary { display: inline-block; background: var(--amber); color: var(--foam); text-decoration: none; padding: 0.9rem 2rem; font-size: 0.9rem; font-weight: 500; letter-spacing: 0.05em; text-transform: uppercase; border-radius: 2px; transition: background 0.2s; }
    .btn-primary:hover { background: var(--gold); }

    footer { background: var(--earth); color: var(--sand); padding: 2.5rem 2rem; }
    .footer-bottom { max-width: 1100px; margin: 0 auto; display: flex; justify-content: space-between; font-size: 0.78rem; color: rgba(242,232,213,0.4); flex-wrap: wrap; gap: 0.5rem; }
    .footer-bottom a { color: var(--amber); text-decoration: none; }

    @media (max-width: 768px) {
      .nav-links { display: none; }
      .nav-toggle { display: block; }
      .nav-links.open { display: flex; flex-direction: column; position: fixed; top: 64px; left: 0; right: 0; background: var(--earth); padding: 1.5rem 2rem; gap: 1.25rem; box-shadow: 0 8px 32px rgba(0,0,0,0.3); }
      .rooms-grid { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>

<nav id="main-nav">
  <a href={base + "/"} class="nav-brand">NALU SURF CAMP</a>
  <ul class="nav-links" id="nav-links">
    <li><a href={base + "/rooms"}>Rooms</a></li>
    <li><a href={base + "/surf"}>Surf</a></li>
    <li><a href={base + "/dining"}>Dining</a></li>
    <li><a href={base + "/contact"} class="nav-cta">Book / Inquire</a></li>
  </ul>
  <button class="nav-toggle" id="nav-toggle" aria-label="Toggle navigation">
    <span class="hamburger"><span></span><span></span><span></span></span>
  </button>
</nav>

<div class="page-hero">
  <div class="page-hero-inner">
    <span class="page-eyebrow">Where You Sleep</span>
    <h1 class="page-title">Six Ways to<br><em>Come Home.</em></h1>
    <p class="page-sub">
      Every room at Nalu is rooted in nipa, bamboo, and natural craft. Choose your level of comfort — from open-air hammocks to premier sea-view huts with all the trimmings.
    </p>
  </div>
</div>

<section class="rooms-section">
  <div class="rooms-inner">
