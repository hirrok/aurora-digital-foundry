      <div class="room-card">
        <img src="https://images.unsplash.com/photo-1596394516093-501ba68a0ba6?auto=format&fit=crop&w=800&q=75" alt="Traditional Nipa Hut" class="room-img" loading="lazy" />
        <div class="room-body">
          <div class="room-type">Classic</div>
          <div class="room-name">Traditional Nipa Hut</div>
          <div class="room-features">Authentic bamboo and nipa palm construction. Fan-cooled with natural airflow. The original camp experience — simple, honest, close to the break.</div>
          <div class="room-amenities">
            <span class="amenity-tag">Fan-cooled</span>
            <span class="amenity-tag">Private bath</span>
            <span class="amenity-tag">Free WiFi</span>
            <span class="amenity-tag">Free breakfast</span>
          </div>
          <div class="room-rate-block">
            <div class="room-rate-label">Rate per night</div>
            <div class="room-rate-value">TODO: Add rate — placeholder only</div>
          </div>
