          </div>
          <a href={base + "/contact"} class="btn-sm">Inquire Now</a>
        </div>
      </div>

      <div class="room-card">
        <img src="https://images.unsplash.com/photo-1439130490301-25e322d88054?auto=format&fit=crop&w=800&q=75" alt="Premier Nipa Hut Sea View" class="room-img" loading="lazy" />
        <div class="room-body">
