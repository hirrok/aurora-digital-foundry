---
// Nalu Surf Camp — Home
// Aurora Digital Foundry · demo mode · scratch build
const title = "Nalu Surf Camp — Stay Wild. Surf Daily. Gather Nightly.";
const description = "26 nipa hut rooms, surf lessons, pool, and a free bonfire every night. Brgy. Sabang, Baler, Aurora.";
const base = "/aurora-digital-foundry/clients/nalu-surf-camp";
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --earth:    #2C1F14;
      --bark:     #4A2E1A;
      --amber:    #C4822A;
      --gold:     #E8A94A;
      --sand:     #F2E8D5;
      --salt:     #FAF6EE;
      --ash:      #8C7B6B;
      --wave:     #2E5F6B;
      --foam:     #FFFFFF;
      --serif:    'Playfair Display', Georgia, serif;
      --sans:     'DM Sans', system-ui, sans-serif;
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: var(--sans);
      background: var(--salt);
      color: var(--earth);
      font-size: 16px;
      line-height: 1.6;
    }

    /* ── NAV ── */
    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1.25rem 2rem;
      background: rgba(44, 31, 20, 0.85);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
    }

    .nav-brand {
      font-family: var(--serif);
      font-size: 1.15rem;
      font-weight: 900;
      color: var(--gold);
      text-decoration: none;
      letter-spacing: 0.04em;
    }

    .nav-links {
      display: flex;
      gap: 2rem;
      list-style: none;
      align-items: center;
    }

    .nav-links a {
      color: var(--sand);
      text-decoration: none;
      font-size: 0.85rem;
      font-weight: 500;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      opacity: 0.85;
      transition: opacity 0.2s;
    }

    .nav-links a:hover { opacity: 1; color: var(--gold); }

    .nav-cta {
      background: var(--amber) !important;
      color: var(--foam) !important;
      padding: 0.5rem 1.25rem !important;
      border-radius: 2px;
      opacity: 1 !important;
      font-weight: 500 !important;
    }

    .nav-cta:hover { background: var(--gold) !important; }

    .nav-toggle {
      display: none;
      background: none;
      border: none;
      cursor: pointer;
      padding: 0.25rem;
    }

    .hamburger { display: flex; flex-direction: column; gap: 5px; }
    .hamburger span { display: block; width: 24px; height: 2px; background: var(--sand); border-radius: 2px; }

    /* ── HERO ── */
    .hero {
      position: relative;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      padding: 6rem 2rem 4rem;
      overflow: hidden;
    }

    .hero-bg {
      position: absolute;
      inset: 0;
      background-image: url('https://images.unsplash.com/photo-1506953823976-52e1fdc0149a?auto=format&fit=crop&w=1800&q=80');
      background-size: cover;
      background-position: center 40%;
    }

    .hero-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(
        to top,
        rgba(28, 16, 8, 0.92) 0%,
        rgba(28, 16, 8, 0.55) 45%,
        rgba(28, 16, 8, 0.25) 100%
      );
    }

    .hero-content {
      position: relative;
      max-width: 780px;
    }

    .hero-eyebrow {
      display: inline-block;
      font-size: 0.78rem;
      font-weight: 500;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 1.25rem;
    }

    .hero-headline {
      font-family: var(--serif);
      font-size: clamp(3rem, 7vw, 5.5rem);
      font-weight: 900;
      line-height: 1.0;
      color: var(--foam);
      margin-bottom: 1.5rem;
    }

    .hero-headline em {
      font-style: italic;
      color: var(--gold);
    }

    .hero-sub {
      font-size: 1.05rem;
      color: rgba(242, 232, 213, 0.85);
      max-width: 520px;
      margin-bottom: 2.5rem;
      line-height: 1.7;
    }

    .hero-actions {
      display: flex;
      gap: 1rem;
      flex-wrap: wrap;
      align-items: center;
    }

    .btn-primary {
      display: inline-block;
      background: var(--amber);
      color: var(--foam);
      text-decoration: none;
      padding: 0.9rem 2rem;
      font-size: 0.9rem;
      font-weight: 500;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      border-radius: 2px;
      transition: background 0.2s;
    }

    .btn-primary:hover { background: var(--gold); }

    .btn-ghost {
      display: inline-block;
      border: 1px solid rgba(242, 232, 213, 0.45);
      color: var(--sand);
      text-decoration: none;
      padding: 0.9rem 2rem;
      font-size: 0.9rem;
      font-weight: 500;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      border-radius: 2px;
      transition: border-color 0.2s, color 0.2s;
    }

    .btn-ghost:hover { border-color: var(--gold); color: var(--gold); }

    .hero-scroll {
      position: absolute;
      bottom: 2.5rem;
      right: 2rem;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.5rem;
      color: rgba(242, 232, 213, 0.5);
      font-size: 0.7rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
    }

    .scroll-line {
      width: 1px;
      height: 48px;
      background: linear-gradient(to bottom, rgba(242,232,213,0.4), transparent);
    }

    /* ── CAMP STRIP ── */
    .camp-strip {
      background: var(--earth);
      padding: 3rem 2rem;
    }

    .camp-strip-inner {
      max-width: 1100px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
      gap: 2rem;
      text-align: center;
    }

    .camp-fact {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.5rem;
    }

    .camp-fact-icon {
      font-size: 1.75rem;
      line-height: 1;
    }

    .camp-fact-label {
      font-size: 0.8rem;
      font-weight: 500;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--gold);
    }

    .camp-fact-value {
      font-size: 0.85rem;
      color: rgba(242, 232, 213, 0.7);
    }

    /* ── SECTION SHARED ── */
    section { padding: 5rem 2rem; }

    .section-inner {
      max-width: 1100px;
      margin: 0 auto;
    }

    .section-label {
      display: inline-block;
      font-size: 0.75rem;
      font-weight: 500;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--amber);
      margin-bottom: 1rem;
    }

    .section-heading {
      font-family: var(--serif);
      font-size: clamp(2rem, 4vw, 3rem);
      font-weight: 900;
      line-height: 1.1;
      color: var(--earth);
      margin-bottom: 1.25rem;
    }

    .section-heading em { font-style: italic; color: var(--amber); }

    .section-body {
      font-size: 1rem;
      color: var(--ash);
      max-width: 560px;
      line-height: 1.75;
      margin-bottom: 2.5rem;
    }

    /* ── ROOMS ── */
    .rooms-section { background: var(--salt); }

    .rooms-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
      gap: 1.5rem;
      margin-top: 3rem;
    }

    .room-card {
      background: var(--foam);
      border-radius: 4px;
      overflow: hidden;
      border: 1px solid rgba(74, 46, 26, 0.1);
      transition: transform 0.25s, box-shadow 0.25s;
    }

    .room-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 12px 40px rgba(44, 31, 20, 0.1);
    }

    .room-img {
      width: 100%;
      aspect-ratio: 4/3;
      object-fit: cover;
      display: block;
    }

    .room-body {
      padding: 1.5rem;
    }

    .room-type {
      font-size: 0.72rem;
      font-weight: 500;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--amber);
      margin-bottom: 0.4rem;
    }

    .room-name {
      font-family: var(--serif);
      font-size: 1.2rem;
      font-weight: 700;
      color: var(--earth);
      margin-bottom: 0.5rem;
    }

    .room-features {
      font-size: 0.85rem;
      color: var(--ash);
      margin-bottom: 1.25rem;
      line-height: 1.6;
    }

    .room-rate {
      font-size: 0.8rem;
      color: var(--ash);
      font-style: italic;
      margin-bottom: 1rem;
    }

    .btn-sm {
      display: inline-block;
      background: var(--earth);
      color: var(--sand);
      text-decoration: none;
      padding: 0.6rem 1.25rem;
      font-size: 0.78rem;
      font-weight: 500;
      letter-spacing: 0.07em;
      text-transform: uppercase;
      border-radius: 2px;
      transition: background 0.2s;
    }

    .btn-sm:hover { background: var(--bark); }

    /* ── BONFIRE ── */
    .bonfire-section {
      background: var(--earth);
      position: relative;
      overflow: hidden;
    }

    .bonfire-section::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0; bottom: 0;
      background: url('https://images.unsplash.com/photo-1475483768296-6163e08872a1?auto=format&fit=crop&w=1600&q=80') center/cover no-repeat;
      opacity: 0.18;
    }

    .bonfire-inner {
      position: relative;
      max-width: 740px;
      margin: 0 auto;
      text-align: center;
    }

    .bonfire-icon {
      font-size: 3.5rem;
      margin-bottom: 1.5rem;
      display: block;
      filter: drop-shadow(0 0 24px rgba(196, 130, 42, 0.6));
    }

    .bonfire-heading {
      font-family: var(--serif);
      font-size: clamp(2.5rem, 5vw, 4rem);
      font-weight: 900;
      font-style: italic;
      color: var(--gold);
      line-height: 1.1;
      margin-bottom: 1.5rem;
    }

    .bonfire-body {
      font-size: 1.05rem;
      color: rgba(242, 232, 213, 0.8);
      line-height: 1.8;
      max-width: 560px;
      margin: 0 auto 2rem;
    }

    .bonfire-tags {
      display: flex;
      justify-content: center;
      gap: 1rem;
      flex-wrap: wrap;
    }

    .tag {
      display: inline-block;
      border: 1px solid rgba(196, 130, 42, 0.4);
      color: var(--gold);
      padding: 0.4rem 1rem;
      font-size: 0.78rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      border-radius: 100px;
    }

    /* ── SURF ── */
    .surf-section {
      background: var(--wave);
    }

    .surf-section .section-heading { color: var(--foam); }
    .surf-section .section-label { color: var(--gold); }
    .surf-section .section-body { color: rgba(255,255,255,0.7); }

    .surf-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 3rem;
      align-items: center;
      margin-top: 1rem;
    }

    .surf-img {
      border-radius: 4px;
      width: 100%;
      aspect-ratio: 4/3;
      object-fit: cover;
      display: block;
    }

    .surf-packages {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .surf-pkg {
      background: rgba(255,255,255,0.08);
      border: 1px solid rgba(255,255,255,0.12);
      border-radius: 4px;
      padding: 1.25rem 1.5rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .surf-pkg-name {
      font-weight: 500;
      color: var(--foam);
      font-size: 0.95rem;
    }

    .surf-pkg-detail {
      font-size: 0.82rem;
      color: rgba(255,255,255,0.55);
      margin-top: 0.2rem;
    }

    .surf-pkg-rate {
      font-family: var(--serif);
      font-size: 0.9rem;
      color: var(--gold);
      font-style: italic;
      white-space: nowrap;
    }

    /* ── DINING ── */
    .dining-section { background: var(--sand); }

    .dining-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 3rem;
      align-items: center;
      margin-top: 1rem;
    }

    .dining-img {
      border-radius: 4px;
      width: 100%;
      aspect-ratio: 3/4;
      object-fit: cover;
      display: block;
    }

    .dining-features {
      display: flex;
      flex-direction: column;
      gap: 1rem;
      margin: 1.5rem 0 2rem;
    }

    .dining-feat {
      display: flex;
      gap: 1rem;
      align-items: flex-start;
    }

    .dining-feat-icon { font-size: 1.4rem; flex-shrink: 0; margin-top: 2px; }

    .dining-feat-text strong {
      display: block;
      font-weight: 500;
      color: var(--earth);
      font-size: 0.9rem;
    }

    .dining-feat-text span {
      font-size: 0.82rem;
      color: var(--ash);
    }

    /* ── MAP ── */
    .map-section { background: var(--foam); padding: 4rem 2rem; }

    .map-grid {
      display: grid;
      grid-template-columns: 1fr 1.4fr;
      gap: 3rem;
      align-items: center;
      max-width: 1100px;
      margin: 0 auto;
    }

    .map-placeholder {
      width: 100%;
      aspect-ratio: 4/3;
      background: rgba(44, 31, 20, 0.06);
      border-radius: 4px;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 0.75rem;
      color: var(--ash);
      font-size: 0.85rem;
      text-align: center;
      border: 1px dashed rgba(74, 46, 26, 0.2);
      padding: 2rem;
    }

    .map-placeholder-icon { font-size: 2.5rem; opacity: 0.5; }

    .map-info { display: flex; flex-direction: column; gap: 1.5rem; }

    .map-info h2 {
      font-family: var(--serif);
      font-size: 2rem;
      font-weight: 900;
      color: var(--earth);
    }

    .map-detail {
      display: flex;
      gap: 1rem;
      align-items: flex-start;
      font-size: 0.9rem;
      color: var(--ash);
    }

    .map-detail-icon { font-size: 1.2rem; flex-shrink: 0; }

    .map-detail strong { color: var(--earth); display: block; font-weight: 500; margin-bottom: 0.15rem; }

    /* ── FOOTER ── */
    footer {
      background: var(--earth);
      color: var(--sand);
      padding: 3rem 2rem;
    }

    .footer-inner {
      max-width: 1100px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 2fr 1fr 1fr;
      gap: 3rem;
    }

    .footer-brand {
      font-family: var(--serif);
      font-size: 1.4rem;
      font-weight: 900;
      color: var(--gold);
      margin-bottom: 0.75rem;
    }

    .footer-tagline {
      font-size: 0.85rem;
      color: rgba(242, 232, 213, 0.55);
      margin-bottom: 1.25rem;
      line-height: 1.6;
    }

    .footer-socials {
      display: flex;
      gap: 0.75rem;
    }

    .footer-socials a {
      display: inline-block;
      border: 1px solid rgba(196, 130, 42, 0.35);
      color: var(--gold);
      padding: 0.35rem 0.85rem;
      font-size: 0.75rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      text-decoration: none;
      border-radius: 2px;
      transition: border-color 0.2s, background 0.2s;
    }

    .footer-socials a:hover { background: rgba(196, 130, 42, 0.15); border-color: var(--gold); }

    .footer-col h4 {
      font-size: 0.72rem;
      font-weight: 500;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 1rem;
    }

    .footer-col ul { list-style: none; display: flex; flex-direction: column; gap: 0.5rem; }

    .footer-col ul li { font-size: 0.85rem; color: rgba(242, 232, 213, 0.65); }

    .footer-col ul li a {
      color: inherit;
      text-decoration: none;
      transition: color 0.2s;
    }

    .footer-col ul li a:hover { color: var(--sand); }

    .footer-bottom {
      max-width: 1100px;
      margin: 2.5rem auto 0;
      padding-top: 1.5rem;
      border-top: 1px solid rgba(242, 232, 213, 0.1);
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-size: 0.78rem;
      color: rgba(242, 232, 213, 0.4);
      flex-wrap: wrap;
      gap: 0.5rem;
    }

    .footer-bottom a { color: var(--amber); text-decoration: none; }

    /* ── MOBILE ── */
    @media (max-width: 768px) {
      .nav-links { display: none; }
      .nav-toggle { display: block; }
      .nav-links.open {
        display: flex;
        flex-direction: column;
        position: fixed;
        top: 64px; left: 0; right: 0;
        background: var(--earth);
        padding: 1.5rem 2rem;
        gap: 1.25rem;
        box-shadow: 0 8px 32px rgba(0,0,0,0.3);
      }
      .nav-links.open li { border-bottom: 1px solid rgba(242,232,213,0.08); padding-bottom: 0.75rem; }
      .nav-links.open .nav-cta { border: none; background: var(--amber) !important; padding: 0.65rem 1.25rem !important; display: inline-block; width: fit-content; }
      .surf-grid { grid-template-columns: 1fr; }
      .dining-grid { grid-template-columns: 1fr; }
      .map-grid { grid-template-columns: 1fr; }
      .footer-inner { grid-template-columns: 1fr; gap: 2rem; }
      .footer-bottom { flex-direction: column; text-align: center; }
      .hero-scroll { display: none; }
    }

    @media (max-width: 480px) {
      nav { padding: 1rem 1.25rem; }
      .hero { padding: 5rem 1.25rem 3rem; }
      section { padding: 3.5rem 1.25rem; }
      .camp-strip { padding: 2rem 1.25rem; }
      .rooms-grid { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>

<!-- NAV -->
<nav id="main-nav">
  <a href={base + "/"} class="nav-brand">NALU SURF CAMP</a>
  <ul class="nav-links" id="nav-links">
    <li><a href={base + "/rooms"}>Rooms</a></li>
    <li><a href={base + "/surf"}>Surf</a></li>
    <li><a href={base + "/dining"}>Dining</a></li>
    <li><a href={base + "/contact"} class="nav-cta">Book / Inquire</a></li>
  </ul>
  <button class="nav-toggle" id="nav-toggle" aria-label="Toggle navigation">
    <span class="hamburger"><span></span><span></span><span></span></span>
  </button>
</nav>

<!-- HERO -->
<section class="hero" aria-label="Hero">
  <div class="hero-bg" role="img" aria-label="Surfer at Sabang Beach, Baler"></div>
  <div class="hero-overlay"></div>
  <div class="hero-content">
    <span class="hero-eyebrow">Brgy. Sabang · Baler, Aurora · Est. on the break</span>
    <h1 class="hero-headline">
      Stay Wild.<br>
      Surf Daily.<br>
      <em>Gather Nightly.</em>
    </h1>
    <p class="hero-sub">
      26 nipa hut rooms steps from Sabang Beach. Surf lessons for every level.
      A pool. A snack bar. And every night — a fire on the beach.
    </p>
    <div class="hero-actions">
      <a href={base + "/contact"} class="btn-primary">Book Your Stay</a>
      <a href={base + "/rooms"} class="btn-ghost">View Rooms</a>
    </div>
  </div>
  <div class="hero-scroll" aria-hidden="true">
    <span>Scroll</span>
    <div class="scroll-line"></div>
  </div>
</section>

<!-- CAMP STRIP -->
<div class="camp-strip">
  <div class="camp-strip-inner">
    <div class="camp-fact">
      <span class="camp-fact-icon">🏡</span>
      <span class="camp-fact-label">26 Rooms</span>
      <span class="camp-fact-value">Nipa hut styles</span>
    </div>
    <div class="camp-fact">
      <span class="camp-fact-icon">🏄</span>
      <span class="camp-fact-label">Surf School</span>
      <span class="camp-fact-value">All levels</span>
    </div>
    <div class="camp-fact">
      <span class="camp-fact-icon">🔥</span>
      <span class="camp-fact-label">Free Bonfire</span>
      <span class="camp-fact-value">Every night</span>
    </div>
    <div class="camp-fact">
      <span class="camp-fact-icon">🏊</span>
      <span class="camp-fact-label">Pool</span>
      <span class="camp-fact-value">On-site</span>
    </div>
    <div class="camp-fact">
      <span class="camp-fact-icon">🐾</span>
      <span class="camp-fact-label">Pet Friendly</span>
      <span class="camp-fact-value">Dogs welcome</span>
    </div>
    <div class="camp-fact">
      <span class="camp-fact-icon">🥞</span>
      <span class="camp-fact-label">Free Breakfast</span>
      <span class="camp-fact-value">7:30–10AM daily</span>
    </div>
  </div>
</div>

<!-- ROOMS -->
<section class="rooms-section">
  <div class="section-inner">
    <span class="section-label">Where You Sleep</span>
    <h2 class="section-heading">Six Ways to <em>Come Home.</em></h2>
    <p class="section-body">
      From traditional nipa huts to premier sea-view rooms — every option is rooted in natural materials, real craftsmanship, and the sound of the Pacific outside your window.
    </p>
