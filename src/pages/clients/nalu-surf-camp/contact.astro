---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const client = {
  name: "Nalu Surf Camp",
  address: "57A Labasin St., Brgy. Sabang, Baler, Aurora",
  phone: "+63 917 817 2606",
  hours: "Check-in 14:00 · Check-out 12:00 · Front Desk 24hrs",
  facebook: "https://facebook.com/NaluSurfCamp",
  messenger: "https://m.me/NaluSurfCamp",
  slug: "nalu-surf-camp",
};
---

<BaseLayout
  title="Contact & Inquiries — Nalu Surf Camp | Baler, Aurora"
  description="Book a room or surf lesson at Nalu Surf Camp. 57A Labasin St., Brgy. Sabang, Baler, Aurora. Check-in 14:00 · Front Desk 24hrs."
  client={client}
>

  <section class="contact-hero container">
    <p class="eyebrow">Get in Touch</p>
    <h1>Book / Inquire</h1>
    <p class="page-sub">
      Questions about rooms, surf lessons, dining, or events?<br />
      Send us a message and we'll get back to you quickly.
    </p>
  </section>

  <section class="contact-body container">
    <div class="contact-grid">

      <!-- FORM -->
      <div class="contact-form-wrap">
        <h2>Send an Inquiry</h2>

        <!-- TODO: Replace action with real Formspree endpoint -->
        <!-- action="https://formspree.io/f/TODO_FORM_ID" -->
        <form
          class="contact-form"
          action="https://formspree.io/f/TODO_REPLACE_WITH_FORMSPREE_ID"
          method="POST"
        >
          <div class="form-group">
            <label for="name">Name</label>
            <input type="text" id="name" name="name" placeholder="Your name" required />
          </div>

          <div class="form-group">
            <label for="contact">Phone / Messenger</label>
            <input type="text" id="contact" name="contact" placeholder="+63 9XX XXX XXXX or Messenger name" required />
          </div>

          <div class="form-group">
            <label for="inquiry_type">Inquiry Type</label>
            <select id="inquiry_type" name="inquiry_type">
              <option value="">Select one…</option>
              <option value="room_booking">Room booking</option>
              <option value="surf_lesson">Surf lesson</option>
              <option value="board_rental">Board rental</option>
              <option value="group_event">Group / event</option>
              <option value="general">General question</option>
            </select>
          </div>

          <div class="form-group">
            <label for="dates">Preferred Dates</label>
            <input type="text" id="dates" name="dates" placeholder="e.g. June 14–16" />
          </div>

          <div class="form-group">
            <label for="message">Message</label>
            <textarea id="message" name="message" rows="5" placeholder="Tell us what you need…" required></textarea>
          </div>

          <button type="submit" class="btn btn--primary btn--full">Send Inquiry</button>
          <p class="form-note todo">TODO: Connect Formspree account — replace action URL with real form ID before launch.</p>
        </form>

        <!-- MESSENGER ALTERNATIVE -->
        <div class="messenger-alt">
          <p>Prefer to message directly?</p>
          <a href={client.messenger} class="btn btn--messenger" target="_blank" rel="noopener noreferrer">
            💬 Message on Facebook
          </a>
          <p class="messenger-note">Fastest response via Messenger.</p>
        </div>
      </div>

      <!-- DETAILS -->
      <div class="contact-details">
        <div class="detail-card">
          <h2>Find Us</h2>

          <div class="detail-item">
            <span class="detail-icon">📍</span>
            <div>
              <p class="detail-label">Address</p>
              <p class="detail-value">{client.address}</p>
              <p class="detail-note">1 minute walk from Sabang Beach.</p>
            </div>
          </div>

          <div class="detail-item">
            <span class="detail-icon">📞</span>
            <div>
              <p class="detail-label">Phone</p>
              <a href={`tel:${client.phone}`} class="detail-value detail-link">{client.phone}</a>
              <p class="detail-note todo">TODO: Verify number with client before publishing.</p>
            </div>
          </div>

          <div class="detail-item">
            <span class="detail-icon">🕐</span>
            <div>
              <p class="detail-label">Hours</p>
              <p class="detail-value">Check-in: 2:00 PM</p>
              <p class="detail-value">Check-out: 12:00 PM</p>
              <p class="detail-value">Front Desk: 24 hours</p>
            </div>
          </div>

          <div class="detail-item">
            <span class="detail-icon">📱</span>
            <div>
              <p class="detail-label">Follow Us</p>
              <a href={client.facebook} class="detail-link" target="_blank" rel="noopener noreferrer">Facebook Page →</a>
            </div>
          </div>
        </div>

        <!-- MAP -->
        <div class="map-wrap">
          <div class="map-placeholder">
            <p class="todo">TODO: Embed Google Maps here<br />Replace with: &lt;iframe src="Google Maps Embed URL" …&gt;</p>
          </div>
        </div>

        <!-- QUICK INFO -->
        <div class="quick-info">
          <h3>Good to Know</h3>
          <ul>
            <li>🐾 Pet-friendly — dogs welcome</li>
            <li>🅿️ Free self-parking on-site</li>
            <li>📶 Free WiFi throughout the property</li>
            <li>🔥 Free bonfire every night</li>
            <li>🍳 Complimentary breakfast 7:30–10AM</li>
            <li>🎸 Acoustic nights</li>
          </ul>
        </div>
      </div>

    </div>
  </section>

</BaseLayout>

<style>
.container { max-width: 1100px; margin: 0 auto; padding: 4rem 1.5rem; }
.eyebrow { color: #0ea5e9; font-size: .8rem; font-weight: 700; letter-spacing: .12em; text-transform: uppercase; margin: 0 0 .4rem; display: block; }
.page-sub { color: #64748b; font-size: 1rem; line-height: 1.65; margin: .5rem 0 0; }
.contact-hero h1 { font-size: clamp(2rem, 5vw, 3rem); font-weight: 900; margin: 0 0 .5rem; }
.todo { color: #f59e0b; font-style: italic; }

.btn { display: inline-block; padding: .75rem 1.75rem; border-radius: 6px; font-weight: 700; font-size: .95rem; text-decoration: none; transition: opacity .15s; cursor: pointer; border: none; }
.btn:hover { opacity: .85; }
.btn--primary { background: #0ea5e9; color: #fff; }
.btn--full { width: 100%; text-align: center; }
.btn--messenger { background: #1877f2; color: #fff; }

/* CONTACT GRID */
.contact-body { padding-top: 0; }
.contact-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; align-items: start; }

/* FORM */
.contact-form-wrap h2 { font-size: 1.3rem; font-weight: 900; margin: 0 0 1.5rem; }
.contact-form { display: flex; flex-direction: column; gap: 1.1rem; }
.form-group { display: flex; flex-direction: column; gap: .35rem; }
.form-group label { font-size: .87rem; font-weight: 600; color: #334155; }
.form-group input,
.form-group select,
.form-group textarea {
  border: 1.5px solid #cbd5e1; border-radius: 7px;
  padding: .7rem .9rem; font-size: .95rem;
  font-family: inherit; background: #fff;
  transition: border-color .15s;
  width: 100%; box-sizing: border-box;
}
.form-group input:focus,
.form-group select:focus,
.form-group textarea:focus { outline: none; border-color: #0ea5e9; }
.form-note { font-size: .8rem; color: #f59e0b; margin: .5rem 0 0; font-style: italic; }

.messenger-alt { margin-top: 2rem; padding-top: 1.75rem; border-top: 1px solid #e2e8f0; text-align: center; }
.messenger-alt p { color: #64748b; font-size: .92rem; margin: 0 0 .75rem; }
.messenger-note { font-size: .82rem; color: #94a3b8; margin: .6rem 0 0; }

/* DETAILS */
.detail-card { background: #f8fafc; border-radius: 12px; padding: 1.75rem; margin-bottom: 1.5rem; }
.detail-card h2 { font-size: 1.2rem; font-weight: 900; margin: 0 0 1.25rem; }
.detail-item { display: flex; gap: .9rem; margin-bottom: 1.25rem; align-items: flex-start; }
.detail-icon { font-size: 1.3rem; flex-shrink: 0; margin-top: .1rem; }
.detail-label { font-size: .78rem; font-weight: 700; text-transform: uppercase; letter-spacing: .08em; color: #94a3b8; margin: 0 0 .2rem; }
.detail-value { font-size: .95rem; font-weight: 600; color: #1e293b; margin: 0 0 .1rem; }
.detail-note { font-size: .8rem; color: #94a3b8; margin: .2rem 0 0; }
.detail-link { color: #0ea5e9; text-decoration: none; font-size: .95rem; font-weight: 600; }

.map-wrap { margin-bottom: 1.5rem; }
.map-placeholder { width: 100%; height: 220px; background: #e2e8f0; border-radius: 10px; display: flex; align-items: center; justify-content: center; text-align: center; padding: 1rem; box-sizing: border-box; }

.quick-info { background: #f0f9ff; border: 1px solid #bae6fd; border-radius: 12px; padding: 1.5rem; }
.quick-info h3 { font-size: 1rem; font-weight: 800; margin: 0 0 .9rem; }
.quick-info ul { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: .45rem; }
.quick-info li { font-size: .9rem; color: #334155; }

/* RESPONSIVE */
@media (max-width: 768px) {
  .contact-grid { grid-template-columns: 1fr; }
}
</style>
