---
import BaseLayout from '../../../layouts/BaseLayout.astro';
const base       = import.meta.env.BASE_URL.replace(/\/$/, '') + '/';
const clientBase = base + 'clients/aliya-surf-camp/';
const packages = [
  {
    level: "Beginner",
    name: "Learn to Surf",
    desc: "First time on a board? Our instructors start you from zero — stance, paddling, pop-up, and your first wave.",
    includes: ["Surfboard rental", "Instructor (1-on-1 or small group)", "Life vest", "1–2 hour session"],
    icon: "🌊",
  },
  {
    level: "Intermediate",
    name: "Improve Your Ride",
    desc: "You can stand up. Now let's work on reading waves, turns, and consistency.",
    includes: ["Board selection guidance", "Focused coaching", "Video feedback (TODO)", "2-hour session"],
    icon: "🏄",
  },
  {
    level: "Board Rental",
    name: "Rent & Rip",
    desc: "You know what you're doing. Just grab a board and go.",
    includes: ["Shortboard / Longboard / Funboard", "Per hour or full day", "Leash included"],
    icon: "🤙",
  },
];

const faqs = [
  { q: "Do I need experience to take lessons?", a: "No. Beginner lessons start from absolute zero. We've taught all ages." },
  { q: "What's the best time to surf at Sabang?", a: "Baler is best July to November for consistent swell. Year-round surfing is possible." },
  { q: "How old do you need to be?", a: "We welcome all ages. Kids and seniors have all learned here. TODO: confirm minimum age with client." },
  { q: "Can I rent a board without a lesson?", a: "Yes. Board rentals are available for those who already surf." },
  { q: "What should I bring?", a: "Rash guard, swimwear, sunscreen, and water. We provide boards and vests." },
];
---
<BaseLayout title="Surf Lessons — Aliya Surf Camp | Baler, Aurora">
  <div class="pt-24 pb-16 md:pb-24">

    <!-- Hero Banner -->
    <div class="relative h-72 mb-16 overflow-hidden">
      <img src="https://images.unsplash.com/photo-1455729552865-3658a5d39692?auto=format&fit=crop&w=1600&q=80"
           alt="Surfing Sabang Beach" class="w-full h-full object-cover"/>
      <div class="absolute inset-0 bg-ocean/70 flex flex-col justify-end p-8 md:p-16">
        <p class="text-sand font-body text-sm uppercase tracking-widest mb-2">Surf School</p>
        <h1 class="font-display font-bold text-white text-4xl md:text-5xl">Learn to Surf at Sabang.</h1>
      </div>
    </div>

    <div class="max-w-6xl mx-auto px-4">
      <!-- Packages -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-16">
        {packages.map(pkg => (
          <div class="bg-foam p-8 border-t-4 border-sunset">
            <div class="text-3xl mb-4">{pkg.icon}</div>
            <p class="text-sunset font-body text-xs uppercase tracking-widest mb-1">{pkg.level}</p>
            <h2 class="font-display font-bold text-ocean text-xl mb-3">{pkg.name}</h2>
            <p class="text-gray-600 font-body text-sm mb-4">{pkg.desc}</p>
            <ul class="text-gray-500 font-body text-xs space-y-1 mb-6">
              {pkg.includes.map(i => <li>✓ {i}</li>)}
            </ul>
            <p class="text-sunset font-semibold text-sm mb-4">
              TODO: Add price — <span class="text-gray-400 italic text-xs">placeholder</span>
            </p>
            <a href={clientBase + 'contact'} class="btn-primary text-xs py-3 block text-center">
              Book Now
            </a>
          </div>
        ))}
      </div>

      <!-- FAQ -->
      <h2 class="section-title mb-8">Common Questions</h2>
      <div class="space-y-4 max-w-2xl">
        {faqs.map(faq => (
          <details class="group bg-white border border-gray-100 shadow-sm">
            <summary class="flex justify-between items-center p-5 cursor-pointer font-body font-semibold text-ocean text-sm">
              {faq.q}
              <span class="text-sunset group-open:rotate-45 transition-transform text-xl">+</span>
            </summary>
            <p class="px-5 pb-5 text-gray-600 font-body text-sm">{faq.a}</p>
          </details>
        ))}
      </div>

      <div class="mt-12">
        <a href={clientBase + 'contact'} class="btn-primary">Book a Lesson</a>
      </div>
    </div>
  </div>
</BaseLayout>
