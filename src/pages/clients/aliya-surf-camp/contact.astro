---
import BaseLayout from '../../../layouts/BaseLayout.astro';
const base       = import.meta.env.BASE_URL.replace(/\/$/, '') + '/';
const clientBase = base + 'clients/aliya-surf-camp/';
---
<BaseLayout title="Contact & Inquiries — Aliya Surf Camp | Baler, Aurora">
  <div class="pt-24 pb-16 md:pb-24">
    <div class="max-w-4xl mx-auto px-4">

      <div class="mt-8 mb-12">
        <p class="text-sunset font-body text-sm uppercase tracking-widest mb-2">Get in Touch</p>
        <h1 class="font-display font-bold text-ocean text-5xl mb-3">Book / Inquire</h1>
        <p class="text-gray-600 font-body">
          Questions about rooms, surf lessons, or dining? Send us a message
          and we'll get back to you as soon as possible.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-12">

        <!-- INQUIRY FORM -->
        <div>
          <form
            action="https://formspree.io/f/TODO_REPLACE_WITH_FORMSPREE_ID"
            method="POST"
            class="space-y-5"
          >
            <div>
              <label class="block font-body text-sm font-semibold text-gray-700 mb-1" for="name">Name</label>
              <input type="text" id="name" name="name" required placeholder="Your name"
                     class="w-full border border-gray-200 px-4 py-3 font-body text-sm focus:outline-none focus:border-wave"/>
            </div>
            <div>
              <label class="block font-body text-sm font-semibold text-gray-700 mb-1" for="phone">Phone / Messenger</label>
              <input type="text" id="phone" name="phone" placeholder="+63 9XX XXX XXXX"
                     class="w-full border border-gray-200 px-4 py-3 font-body text-sm focus:outline-none focus:border-wave"/>
            </div>
            <div>
              <label class="block font-body text-sm font-semibold text-gray-700 mb-1" for="inquiry">Inquiry Type</label>
              <select id="inquiry" name="inquiry"
                      class="w-full border border-gray-200 px-4 py-3 font-body text-sm focus:outline-none focus:border-wave bg-white">
                <option>Room booking</option>
                <option>Surf lesson</option>
                <option>Board rental</option>
                <option>Group / event</option>
                <option>General question</option>
              </select>
            </div>
            <div>
              <label class="block font-body text-sm font-semibold text-gray-700 mb-1" for="dates">Preferred Dates</label>
              <input type="text" id="dates" name="dates" placeholder="e.g. June 15–18"
                     class="w-full border border-gray-200 px-4 py-3 font-body text-sm focus:outline-none focus:border-wave"/>
            </div>
            <div>
              <label class="block font-body text-sm font-semibold text-gray-700 mb-1" for="message">Message</label>
              <textarea id="message" name="message" rows="4" placeholder="Tell us what you need..."
                        class="w-full border border-gray-200 px-4 py-3 font-body text-sm focus:outline-none focus:border-wave resize-none"></textarea>
            </div>
            <button type="submit" class="btn-primary w-full py-4">
              Send Inquiry
            </button>
            <p class="text-xs text-gray-400 font-body">
              TODO: Connect Formspree or replace with Messenger/WhatsApp link
            </p>
          </form>
        </div>

        <!-- CONTACT INFO + MAP -->
        <div class="space-y-8">
          <div>
            <h2 class="font-display font-bold text-ocean text-xl mb-4">Find Us</h2>
            <p class="text-gray-600 font-body text-sm mb-1">📍 Button St., Brgy. Sabang, Baler, Aurora</p>
            <p class="text-gray-600 font-body text-sm mb-1">📞 TODO: Add phone number</p>
            <p class="text-gray-600 font-body text-sm mb-1">🕐 Open Daily · Front Desk 7AM–10PM</p>
            <a href="https://facebook.com/aliyasurfcamp" target="_blank" rel="noopener noreferrer"
               class="text-wave font-body text-sm font-semibold hover:text-ocean transition-colors">
              Facebook Page →
            </a>
          </div>

          <!-- Map placeholder -->
          <div class="h-64 bg-foam border border-wave/30 flex items-center justify-center">
            <p class="text-ocean font-body text-sm text-center px-4">
              TODO: Embed Google Maps<br/>
              <span class="text-xs text-gray-400">Sabang Beach, Baler, Aurora</span>
            </p>
          </div>

          <div class="bg-ocean text-white p-6">
            <p class="font-display font-bold mb-2">Prefer to message directly?</p>
            <p class="text-white/70 font-body text-sm mb-4">
              Reach us on Facebook Messenger for the fastest response.
            </p>
            <a href="https://m.me/aliyasurfcamp" target="_blank" rel="noopener noreferrer"
               class="btn-outline text-xs py-3 inline-block">
              Message on Facebook
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
