---
const base = "/aurora-digital-foundry/clients/ecopetrol-aurora";
---
<style>
  .eco-nav {
    background: #002D6E;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 2rem;
    height: 64px;
    position: sticky;
    top: 0;
    z-index: 100;
    border-bottom: 3px solid #005BAC;
    font-family: 'Barlow Condensed', sans-serif;
  }
  .eco-logo {
    font-size: 1.4rem;
    font-weight: 900;
    color: #fff;
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    letter-spacing: 0.04em;
    z-index: 2;
  }
  .eco-logo .dot { color: #005BAC; font-size: 2rem; line-height: 0; }
  .eco-nav-links {
    display: flex;
    gap: 1.25rem;
    list-style: none;
    align-items: center;
  }
  .eco-nav-links a {
    color: #AABDD8;
    text-decoration: none;
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    transition: color 0.2s;
    white-space: nowrap;
  }
  .eco-nav-links a:hover { color: #fff; }
  .eco-nav-links .nav-cta {
    background: #005BAC;
    color: #fff !important;
    padding: 0.4rem 1rem;
    transition: background 0.2s;
  }
  .eco-nav-links .nav-cta:hover { background: #0066CC; }

  /* Hamburger button */
  .eco-ham {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 10px;
    z-index: 2;
    -webkit-tap-highlight-color: transparent;
  }
  .eco-ham span {
    display: block;
    width: 22px;
    height: 2px;
    background: #fff;
    border-radius: 2px;
    transition: transform 0.25s ease, opacity 0.2s ease;
    transform-origin: center;
  }
  .eco-ham.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .eco-ham.open span:nth-child(2) { opacity: 0; transform: scaleX(0); }
  .eco-ham.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  @media (max-width: 900px) {
    .eco-ham { display: flex; }

    .eco-nav-links {
      display: none;
      position: absolute;
      top: 67px;
      left: 0;
      right: 0;
      flex-direction: column;
      background: #002D6E;
      padding: 0.5rem 0 1.25rem;
      border-bottom: 3px solid #005BAC;
      box-shadow: 0 12px 32px rgba(0, 0, 0, 0.35);
      gap: 0;
      align-items: stretch;
    }
    .eco-nav-links.open { display: flex; }

    .eco-nav-links li {
      border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    }
    .eco-nav-links li:last-child { border-bottom: none; }

    .eco-nav-links a {
      display: block;
      padding: 0.9rem 2rem;
      font-size: 1rem;
      letter-spacing: 0.08em;
      color: rgba(255, 255, 255, 0.8);
    }
    .eco-nav-links a:hover {
      background: rgba(255, 255, 255, 0.05);
      color: #fff;
    }
    .eco-nav-links .nav-cta {
      margin: 1rem 2rem 0;
      text-align: center;
      padding: 0.8rem 1rem;
      border-radius: 0;
    }
  }
</style>

<nav class="eco-nav">
  <a href={base} class="eco-logo"><span class="dot">&middot;</span> ECOPETROL</a>
  <ul class="eco-nav-links" id="ecoNavLinks">
    <li><a href={`${base}/branches`}>Branches</a></li>
    <li><a href={`${base}/prices`}>Prices</a></li>
    <li><a href={`${base}/lpg`}>LPG / Solane</a></li>
    <li><a href={`${base}/fleet`}>Fleet</a></li>
    <li><a href={`${base}/franchise`}>Franchise</a></li>
    <li><a href={`${base}/about`}>About</a></li>
    <li><a href={`${base}/contact`} class="nav-cta">Contact Us</a></li>
  </ul>
  <button
    class="eco-ham"
    aria-label="Toggle navigation"
    aria-expanded="false"
    onclick="
      const btn = this;
      const nav = document.getElementById('ecoNavLinks');
      const open = nav.classList.toggle('open');
      btn.classList.toggle('open', open);
      btn.setAttribute('aria-expanded', open);
    "
  >
    <span></span>
    <span></span>
    <span></span>
  </button>
</nav>
